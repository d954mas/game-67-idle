{
  "schema_version": 1,
  "layers": [
    {
      "id": "portable_ai_pipeline",
      "meaning": "Generic AI workflow tools that should move to a clean new game project.",
      "new_game_policy": "copy",
      "paths": [
        "tools/ai.mjs",
        "tools/ai.test.mjs",
        "tools/ai_profile/",
        "tools/bootstrap/export_base.mjs",
        "tools/game_context/",
        "tools/pipeline_validate.mjs",
        "tools/skills_eval.mjs",
        "tools/skills_sync.mjs",
        "tools/taskboard/",
        "tools/assets/new_art_job.mjs"
      ]
    },
    {
      "id": "reusable_game_infrastructure",
      "meaning": "Game/runtime infrastructure that can be reused when the next game keeps a compatible native/devapi/state stack.",
      "new_game_policy": "copy_when_runtime_matches_or_adapt",
      "paths": [
        "tools/state_codegen/",
        "tools/devapi/agent_playtest.py",
        "tools/devapi/bot_demo.py",
        "tools/devapi/capture_demo.py",
        "tools/devapi/capture_screen.ps1",
        "tools/devapi/capture_window.py",
        "tools/devapi/devapi_cli.py",
        "tools/devapi/devapi_client.py",
        "tools/devapi/full_probe.py",
        "tools/devapi/pixel_health.py",
        "tools/devapi/record_screen_ffmpeg.ps1",
        "tools/devapi/smoke_test.py"
      ]
    },
    {
      "id": "project_specific_67_world",
      "meaning": "67 World, release, balance, package, and asset scripts. Do not carry these into a different game unless intentionally adapting them.",
      "new_game_policy": "delete_or_archive_on_new_game",
      "paths": [
        "tools/project_67_world/",
        "tools/project_67_world/assets/build_67_world_art.py",
        "tools/project_67_world/assets/build_67_world_packs.c",
        "tools/project_67_world/assets/make_windows_icon.py",
        "tools/project_67_world/assets/validate_67_world_pack_inputs.py",
        "tools/project_67_world/balance/simulate_67_world.py",
        "tools/project_67_world/devapi_scenarios/autosave_state.py",
        "tools/project_67_world/devapi_scenarios/better_crate_progression.py",
        "tools/project_67_world/devapi_scenarios/child_test_readiness.py",
        "tools/project_67_world/devapi_scenarios/evidence_capture.py",
        "tools/project_67_world/devapi_scenarios/extended_67_progression.py",
        "tools/project_67_world/devapi_scenarios/first_67_loop.py",
        "tools/project_67_world/devapi_scenarios/full_board_density.py",
        "tools/project_67_world/devapi_scenarios/mobile_portrait_layout.py",
        "tools/project_67_world/devapi_scenarios/one_hour_progression_runtime.py",
        "tools/project_67_world/devapi_scenarios/package_release_smoke.py",
        "tools/project_67_world/devapi_scenarios/package_save_isolation.py",
        "tools/project_67_world/devapi_scenarios/settings_modal.py",
        "tools/project_67_world/devapi_scenarios/state_roundtrip.py",
        "tools/project_67_world/devapi_scenarios/ui_button_text.py",
        "tools/project_67_world/package_native_release.mjs",
        "tools/project_67_world/release_candidate_audit.py"
      ]
    },
    {
      "id": "generated_cache",
      "meaning": "Interpreter/build caches. These are ignored scratch artifacts and can be deleted at any time.",
      "new_game_policy": "never_copy",
      "patterns": [
        "tools/**/__pycache__/",
        "tools/**/*.pyc"
      ]
    }
  ]
}
