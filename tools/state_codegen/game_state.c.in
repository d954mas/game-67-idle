#include "game_state.h"
#include "game_state_schema.gen.h"

#include <stdio.h>
#include <stdlib.h>
#include <string.h>
#include <errno.h>
#ifdef _WIN32
#include <direct.h>
#include <windows.h>
#else
#include <sys/stat.h>
#endif

#define GAME_STATE_MAX_FILE_BYTES (1024 * 1024)
#define GAME_STATE_PATH_MAX 512

typedef bool (*game_state_migration_fn)(cJSON *state, char *error, int error_cap);

bool game_state_migrate_v0_to_v1(cJSON *state, char *error, int error_cap);
bool game_state_migrate_v1_to_v2(cJSON *state, char *error, int error_cap);
bool game_state_migrate_v2_to_v3(cJSON *state, char *error, int error_cap);

typedef struct GameStateMigration {
    int from_version;
    int to_version;
    game_state_migration_fn fn;
} GameStateMigration;

static const GameStateMigration k_migrations[] = {
    {0, 1, game_state_migrate_v0_to_v1},
    {1, 2, game_state_migrate_v1_to_v2},
    {2, 3, game_state_migrate_v2_to_v3},
};

/*@GEN:ENUM_TABLES@*/

GameState g_game_state;

static game_state_changed_fn s_changed;
static void *s_changed_user;
static bool s_dirty;

static void set_error(char *error, int error_cap, const char *message) {
    if (error && error_cap > 0) {
        (void)snprintf(error, (size_t)error_cap, "%s", message);
    }
}

static bool copy_text(char *dst, size_t dst_cap, const char *src) {
    if (!dst || dst_cap == 0 || !src || strlen(src) >= dst_cap) {
        return false;
    }
    (void)snprintf(dst, dst_cap, "%s", src);
    return true;
}

static const cJSON *object_item(const cJSON *obj, const char *name) {
    return cJSON_IsObject(obj) ? cJSON_GetObjectItemCaseSensitive(obj, name) : NULL;
}

static bool read_bool(const cJSON *obj, const char *name, bool *out, char *error, int error_cap) {
    const cJSON *item = object_item(obj, name);
    if (!item) {
        return true;
    }
    if (!cJSON_IsBool(item)) {
        set_error(error, error_cap, "expected bool");
        return false;
    }
    *out = cJSON_IsTrue(item);
    return true;
}

static bool read_int_range(const cJSON *obj, const char *name, int min_value, int max_value, int *out, char *error, int error_cap) {
    const cJSON *item = object_item(obj, name);
    if (!item) {
        return true;
    }
    if (!cJSON_IsNumber(item)) {
        set_error(error, error_cap, "expected number");
        return false;
    }
    double number = item->valuedouble;
    if (number < (double)min_value || number > (double)max_value || number != (double)(int)number) {
        set_error(error, error_cap, "number out of range");
        return false;
    }
    int value = (int)number;
    *out = value;
    return true;
}

static bool read_float_range(const cJSON *obj, const char *name, float min_value, float max_value, float *out, char *error, int error_cap) {
    const cJSON *item = object_item(obj, name);
    if (!item) {
        return true;
    }
    if (!cJSON_IsNumber(item)) {
        set_error(error, error_cap, "expected number");
        return false;
    }
    float value = (float)item->valuedouble;
    if (value < min_value || value > max_value) {
        set_error(error, error_cap, "number out of range");
        return false;
    }
    *out = value;
    return true;
}

static bool read_string(const cJSON *obj, const char *name, char *out, size_t out_cap, char *error, int error_cap) {
    const cJSON *item = object_item(obj, name);
    if (!item) {
        return true;
    }
    if (!cJSON_IsString(item) || !copy_text(out, out_cap, item->valuestring)) {
        set_error(error, error_cap, "expected short string");
        return false;
    }
    return true;
}

static int enum_index(const char *value, const char *const *names, int count) {
    if (!value) {
        return -1;
    }
    for (int i = 0; i < count; i++) {
        if (strcmp(value, names[i]) == 0) {
            return i;
        }
    }
    return -1;
}

static bool read_enum(const cJSON *obj, const char *name, const char *const *names, int count, int *out, char *error, int error_cap) {
    const cJSON *item = object_item(obj, name);
    if (!item) {
        return true;
    }
    int value = -1;
    if (cJSON_IsString(item)) {
        value = enum_index(item->valuestring, names, count);
    } else if (cJSON_IsNumber(item)) {
        double number = item->valuedouble;
        if (number != (double)(int)number) {
            set_error(error, error_cap, "enum value must be an integer");
            return false;
        }
        value = (int)number;
    } else {
        set_error(error, error_cap, "expected enum string or number");
        return false;
    }
    if (value < 0 || value >= count) {
        set_error(error, error_cap, "enum value out of range");
        return false;
    }
    *out = value;
    return true;
}

static bool parse_enum_value(const cJSON *item, const char *const *names, int count, int *out, char *error, int error_cap) {
    int value = -1;
    if (cJSON_IsString(item)) {
        value = enum_index(item->valuestring, names, count);
    } else if (cJSON_IsNumber(item)) {
        double number = item->valuedouble;
        if (number != (double)(int)number) {
            set_error(error, error_cap, "enum value must be an integer");
            return false;
        }
        value = (int)number;
    } else {
        set_error(error, error_cap, "expected enum string or number");
        return false;
    }
    if (value < 0 || value >= count) {
        set_error(error, error_cap, "enum value out of range");
        return false;
    }
    *out = value;
    return true;
}

static bool parse_int_value(const cJSON *item, int min_value, int max_value, int *out, char *error, int error_cap) {
    if (!cJSON_IsNumber(item)) {
        set_error(error, error_cap, "expected integer");
        return false;
    }
    double number = item->valuedouble;
    if (number < (double)min_value || number > (double)max_value || number != (double)(int)number) {
        set_error(error, error_cap, "integer value out of range");
        return false;
    }
    *out = (int)number;
    return true;
}

static bool notify_changed(const char *path, char *error, int error_cap) {
    if (!s_changed) {
        return true;
    }
    return s_changed(path, s_changed_user, error, error_cap);
}

void game_state_init_defaults(GameState *state) {
    memset(state, 0, sizeof(*state));
/*@GEN:DEFAULTS@*/
}

void game_state_init(void) {
    game_state_init_defaults(&g_game_state);
}

void game_state_set_changed_callback(game_state_changed_fn callback, void *user) {
    s_changed = callback;
    s_changed_user = user;
}

void game_state_mark_dirty(void) {
    s_dirty = true;
}

bool game_state_is_dirty(void) {
    return s_dirty;
}

void game_state_clear_dirty(void) {
    s_dirty = false;
}

static bool state_has_item_id(const GameState *state, const char *instance_id) {
    if (!instance_id || instance_id[0] == '\0') {
        return false;
    }
    for (int i = 0; i < GAME_STATE_MAX_ITEMS; i++) {
        if (state->items[i].used && strcmp(state->items[i].instance_id, instance_id) == 0) {
            return true;
        }
    }
    return false;
}

bool game_state_validate(const GameState *state, char *error, int error_cap) {
    if (!state) {
        set_error(error, error_cap, "state is null");
        return false;
    }
/*@GEN:VALIDATE@*/
    if (state->inventory_item_ids_count < 0 || state->inventory_item_ids_count > GAME_STATE_MAX_INVENTORY_ITEM_IDS) {
        set_error(error, error_cap, "inventory_item_ids_count out of range");
        return false;
    }
    for (int i = 0; i < state->inventory_item_ids_count; i++) {
        if (!state_has_item_id(state, state->inventory_item_ids[i])) {
            set_error(error, error_cap, "inventory item id does not exist");
            return false;
        }
    }
    if (state->has_equipment_hand_item_id && !state_has_item_id(state, state->equipment_hand_item_id)) {
        set_error(error, error_cap, "equipment hand item id does not exist");
        return false;
    }
    for (int i = 0; i < GAME_STATE_MAX_ITEMS; i++) {
        const GameItemInstance *item = &state->items[i];
        if (!item->used) {
            continue;
        }
        if (item->instance_id[0] == '\0' || item->def_id[0] == '\0') {
            set_error(error, error_cap, "item id is empty");
            return false;
        }
        if (item->count < GAME_STATE_ITEM_COUNT_MIN || item->count > GAME_STATE_ITEM_COUNT_MAX ||
            item->level < GAME_STATE_ITEM_LEVEL_MIN || item->level > GAME_STATE_ITEM_LEVEL_MAX ||
            item->durability < GAME_STATE_ITEM_DURABILITY_MIN || item->durability > GAME_STATE_ITEM_DURABILITY_MAX) {
            set_error(error, error_cap, "item value out of range");
            return false;
        }
    }
    return true;
}

cJSON *game_state_schema_json(void) {
    const char *chunks[] = GAME_STATE_SCHEMA_JSON_CHUNKS;
    size_t len = 0;
    for (size_t i = 0; chunks[i][0] != '\0'; i++) {
        len += strlen(chunks[i]);
    }
    char *json = (char *)malloc(len + 1U);
    if (!json) {
        return cJSON_CreateObject();
    }
    char *cursor = json;
    for (size_t i = 0; chunks[i][0] != '\0'; i++) {
        size_t chunk_len = strlen(chunks[i]);
        memcpy(cursor, chunks[i], chunk_len);
        cursor += chunk_len;
    }
    json[len] = '\0';
    cJSON *root = cJSON_Parse(json);
    free(json);
    return root ? root : cJSON_CreateObject();
}

static cJSON *item_to_json(const GameItemInstance *item) {
    cJSON *obj = cJSON_CreateObject();
    cJSON_AddStringToObject(obj, "def_id", item->def_id);
    cJSON_AddNumberToObject(obj, "count", item->count);
    cJSON_AddNumberToObject(obj, "level", item->level);
    cJSON_AddNumberToObject(obj, "durability", (double)item->durability);
    return obj;
}

cJSON *game_state_to_json(const GameState *state) {
    cJSON *root = cJSON_CreateObject();
/*@GEN:TO_JSON@*/

    cJSON *items = cJSON_AddObjectToObject(root, "items");
    for (int i = 0; i < GAME_STATE_MAX_ITEMS; i++) {
        if (state->items[i].used) {
            cJSON_AddItemToObject(items, state->items[i].instance_id, item_to_json(&state->items[i]));
        }
    }

    cJSON *inventory = cJSON_AddObjectToObject(root, "inventory");
    cJSON *ids = cJSON_AddArrayToObject(inventory, "item_ids");
    for (int i = 0; i < state->inventory_item_ids_count; i++) {
        cJSON_AddItemToArray(ids, cJSON_CreateString(state->inventory_item_ids[i]));
    }

    cJSON *equipment = cJSON_AddObjectToObject(root, "equipment");
    if (state->has_equipment_hand_item_id) {
        cJSON_AddStringToObject(equipment, "hand_item_id", state->equipment_hand_item_id);
    } else {
        cJSON_AddNullToObject(equipment, "hand_item_id");
    }
    return root;
}

static GameItemInstance *find_item(GameState *state, const char *instance_id) {
    for (int i = 0; i < GAME_STATE_MAX_ITEMS; i++) {
        if (state->items[i].used && strcmp(state->items[i].instance_id, instance_id) == 0) {
            return &state->items[i];
        }
    }
    return NULL;
}

static const GameItemInstance *find_item_const(const GameState *state, const char *instance_id) {
    for (int i = 0; i < GAME_STATE_MAX_ITEMS; i++) {
        if (state->items[i].used && strcmp(state->items[i].instance_id, instance_id) == 0) {
            return &state->items[i];
        }
    }
    return NULL;
}

static GameItemInstance *alloc_item(GameState *state, const char *instance_id) {
    GameItemInstance *existing = find_item(state, instance_id);
    if (existing) {
        return existing;
    }
    for (int i = 0; i < GAME_STATE_MAX_ITEMS; i++) {
        if (!state->items[i].used) {
            memset(&state->items[i], 0, sizeof(state->items[i]));
            state->items[i].used = true;
            if (!copy_text(state->items[i].instance_id, sizeof(state->items[i].instance_id), instance_id)) {
                state->items[i].used = false;
                return NULL;
            }
            state->items[i].count = GAME_STATE_ITEM_COUNT_DEFAULT;
            state->items[i].level = GAME_STATE_ITEM_LEVEL_DEFAULT;
            state->items[i].durability = GAME_STATE_ITEM_DURABILITY_DEFAULT;
            return &state->items[i];
        }
    }
    return NULL;
}

static bool set_item_from_json(GameItemInstance *item, const cJSON *json, char *error, int error_cap) {
    if (!cJSON_IsObject(json)) {
        set_error(error, error_cap, "item must be object");
        return false;
    }
    if (!read_string(json, "def_id", item->def_id, sizeof(item->def_id), error, error_cap)) {
        return false;
    }
    if (item->def_id[0] == '\0') {
        set_error(error, error_cap, "item def_id is required");
        return false;
    }
    return read_int_range(json, "count", GAME_STATE_ITEM_COUNT_MIN, GAME_STATE_ITEM_COUNT_MAX, &item->count, error, error_cap) &&
           read_int_range(json, "level", GAME_STATE_ITEM_LEVEL_MIN, GAME_STATE_ITEM_LEVEL_MAX, &item->level, error, error_cap) &&
           read_float_range(json, "durability", GAME_STATE_ITEM_DURABILITY_MIN, GAME_STATE_ITEM_DURABILITY_MAX, &item->durability, error, error_cap);
}

static bool set_items_from_json(GameState *state, const cJSON *json, char *error, int error_cap) {
    if (!cJSON_IsObject(json)) {
        set_error(error, error_cap, "items must be object");
        return false;
    }
    for (int i = 0; i < GAME_STATE_MAX_ITEMS; i++) {
        memset(&state->items[i], 0, sizeof(state->items[i]));
    }
    const cJSON *item_json = NULL;
    cJSON_ArrayForEach(item_json, json) {
        if (!item_json->string) {
            continue;
        }
        GameItemInstance *item = alloc_item(state, item_json->string);
        if (!item) {
            set_error(error, error_cap, "too many items or long item id");
            return false;
        }
        if (!set_item_from_json(item, item_json, error, error_cap)) {
            return false;
        }
    }
    return true;
}

static bool set_inventory_ids_from_json(GameState *state, const cJSON *json, char *error, int error_cap) {
    if (!cJSON_IsArray(json)) {
        set_error(error, error_cap, "inventory.item_ids must be array");
        return false;
    }
    int count = cJSON_GetArraySize((cJSON *)json);
    if (count > GAME_STATE_MAX_INVENTORY_ITEM_IDS) {
        set_error(error, error_cap, "too many inventory ids");
        return false;
    }
    state->inventory_item_ids_count = 0;
    for (int i = 0; i < count; i++) {
        const cJSON *id = cJSON_GetArrayItem((cJSON *)json, i);
        if (!cJSON_IsString(id) || !copy_text(state->inventory_item_ids[i], sizeof(state->inventory_item_ids[i]), id->valuestring)) {
            set_error(error, error_cap, "inventory id must be short string");
            return false;
        }
        state->inventory_item_ids_count++;
    }
    return true;
}

cJSON *game_state_get_path_json(const GameState *state, const char *path, char *error, int error_cap) {
    if (!path || path[0] == '\0') {
        return game_state_to_json(state);
    }
/*@GEN:GET_PATH@*/
    if (strcmp(path, "items") == 0) {
        cJSON *items = cJSON_CreateObject();
        for (int i = 0; i < GAME_STATE_MAX_ITEMS; i++) {
            if (state->items[i].used) {
                cJSON_AddItemToObject(items, state->items[i].instance_id, item_to_json(&state->items[i]));
            }
        }
        return items;
    }
    if (strncmp(path, "items.", 6) == 0) {
        const char *id = path + 6;
        const char *field = strchr(id, '.');
        char instance_id[GAME_STATE_STRING_MAX];
        if (field) {
            size_t len = (size_t)(field - id);
            if (len == 0 || len >= sizeof(instance_id)) {
                set_error(error, error_cap, "bad item id");
                return NULL;
            }
            memcpy(instance_id, id, len);
            instance_id[len] = '\0';
            field++;
        } else if (!copy_text(instance_id, sizeof(instance_id), id)) {
            set_error(error, error_cap, "bad item id");
            return NULL;
        }
        const GameItemInstance *item = find_item_const(state, instance_id);
        if (!item) {
            set_error(error, error_cap, "unknown item id");
            return NULL;
        }
        if (!field) {
            return item_to_json(item);
        }
        if (strcmp(field, "def_id") == 0) {
            return cJSON_CreateString(item->def_id);
        }
        if (strcmp(field, "count") == 0) {
            return cJSON_CreateNumber(item->count);
        }
        if (strcmp(field, "level") == 0) {
            return cJSON_CreateNumber(item->level);
        }
        if (strcmp(field, "durability") == 0) {
            return cJSON_CreateNumber((double)item->durability);
        }
    }
    if (strcmp(path, "inventory.item_ids") == 0) {
        cJSON *ids = cJSON_CreateArray();
        for (int i = 0; i < state->inventory_item_ids_count; i++) {
            cJSON_AddItemToArray(ids, cJSON_CreateString(state->inventory_item_ids[i]));
        }
        return ids;
    }
    if (strcmp(path, "equipment.hand_item_id") == 0) {
        return state->has_equipment_hand_item_id ? cJSON_CreateString(state->equipment_hand_item_id) : cJSON_CreateNull();
    }
    set_error(error, error_cap, "unknown state path");
    return NULL;
}

bool game_state_set_path_json(GameState *state, const char *path, const cJSON *value, char *error, int error_cap) {
    if (!state || !path || !path[0] || !value) {
        set_error(error, error_cap, "path and value are required");
        return false;
    }
/*@GEN:SET_PATH@*/
    if (strcmp(path, "items") == 0) {
        if (!set_items_from_json(state, value, error, error_cap)) {
            return false;
        }
        return true;
    }
    if (strncmp(path, "items.", 6) == 0) {
        const char *id = path + 6;
        const char *field = strchr(id, '.');
        char instance_id[GAME_STATE_STRING_MAX];
        if (field) {
            size_t len = (size_t)(field - id);
            if (len == 0 || len >= sizeof(instance_id)) {
                set_error(error, error_cap, "bad item id");
                return false;
            }
            memcpy(instance_id, id, len);
            instance_id[len] = '\0';
            field++;
        } else if (!copy_text(instance_id, sizeof(instance_id), id)) {
            set_error(error, error_cap, "bad item id");
            return false;
        }
        GameItemInstance *item = alloc_item(state, instance_id);
        if (!item) {
            set_error(error, error_cap, "too many items or long item id");
            return false;
        }
        if (!field) {
            if (!set_item_from_json(item, value, error, error_cap)) {
                return false;
            }
        } else if (strcmp(field, "def_id") == 0) {
            if (!cJSON_IsString(value) || !copy_text(item->def_id, sizeof(item->def_id), value->valuestring)) {
                set_error(error, error_cap, "def_id expects short string");
                return false;
            }
        } else if (strcmp(field, "count") == 0) {
            int count = 0;
            if (!parse_int_value(value, GAME_STATE_ITEM_COUNT_MIN, GAME_STATE_ITEM_COUNT_MAX, &count, error, error_cap)) {
                return false;
            }
            item->count = count;
        } else if (strcmp(field, "level") == 0) {
            int level = 0;
            if (!parse_int_value(value, GAME_STATE_ITEM_LEVEL_MIN, GAME_STATE_ITEM_LEVEL_MAX, &level, error, error_cap)) {
                return false;
            }
            item->level = level;
        } else if (strcmp(field, "durability") == 0) {
            if (!cJSON_IsNumber(value) || value->valuedouble < (double)GAME_STATE_ITEM_DURABILITY_MIN || value->valuedouble > (double)GAME_STATE_ITEM_DURABILITY_MAX) {
                set_error(error, error_cap, "durability out of range");
                return false;
            }
            item->durability = (float)value->valuedouble;
        } else {
            set_error(error, error_cap, "unknown item field");
            return false;
        }
        return true;
    }
    if (strcmp(path, "inventory.item_ids") == 0) {
        if (!set_inventory_ids_from_json(state, value, error, error_cap)) {
            return false;
        }
        return true;
    }
    if (strcmp(path, "equipment.hand_item_id") == 0) {
        if (cJSON_IsNull(value)) {
            state->has_equipment_hand_item_id = false;
            state->equipment_hand_item_id[0] = '\0';
            return true;
        }
        if (!cJSON_IsString(value) || !copy_text(state->equipment_hand_item_id, sizeof(state->equipment_hand_item_id), value->valuestring)) {
            set_error(error, error_cap, "equipment.hand_item_id expects short string or null");
            return false;
        }
        state->has_equipment_hand_item_id = true;
        return true;
    }
    set_error(error, error_cap, "unknown state path");
    return false;
}

bool game_state_patch_json(GameState *state, const cJSON *values, char *error, int error_cap) {
    if (!cJSON_IsObject(values)) {
        set_error(error, error_cap, "values must be an object");
        return false;
    }
    GameState next = *state;
    const cJSON *item = NULL;
    cJSON_ArrayForEach(item, values) {
        if (!item->string || !game_state_set_path_json(&next, item->string, item, error, error_cap)) {
            return false;
        }
    }
    if (!game_state_validate(&next, error, error_cap)) {
        return false;
    }
    GameState old = *state;
    *state = next;
    if (!notify_changed("*", error, error_cap)) {
        *state = old;
        return false;
    }
    if (state == &g_game_state) {
        game_state_mark_dirty();
    }
    return true;
}

bool game_state_from_json(GameState *state, const cJSON *json, char *error, int error_cap) {
    if (!cJSON_IsObject(json)) {
        set_error(error, error_cap, "state json must be object");
        return false;
    }
    GameState next;
    game_state_init_defaults(&next);

/*@GEN:FROM_JSON@*/
    const cJSON *items = object_item(json, "items");
    if (items && !set_items_from_json(&next, items, error, error_cap)) {
        return false;
    }
    const cJSON *inventory = object_item(json, "inventory");
    const cJSON *item_ids = object_item(inventory, "item_ids");
    if (item_ids && !set_inventory_ids_from_json(&next, item_ids, error, error_cap)) {
        return false;
    }
    const cJSON *equipment = object_item(json, "equipment");
    const cJSON *hand = object_item(equipment, "hand_item_id");
    if (hand) {
        if (cJSON_IsNull(hand)) {
            next.has_equipment_hand_item_id = false;
        } else if (cJSON_IsString(hand) && copy_text(next.equipment_hand_item_id, sizeof(next.equipment_hand_item_id), hand->valuestring)) {
            next.has_equipment_hand_item_id = true;
        } else {
            set_error(error, error_cap, "equipment.hand_item_id must be string or null");
            return false;
        }
    }
    if (!game_state_validate(&next, error, error_cap)) {
        return false;
    }
    *state = next;
    return true;
}

static cJSON *make_save_doc(const GameState *state) {
    cJSON *doc = cJSON_CreateObject();
    cJSON_AddStringToObject(doc, "schema", GAME_STATE_SCHEMA_ID);
    cJSON_AddStringToObject(doc, "document", "game");
    cJSON_AddNumberToObject(doc, "version", GAME_STATE_VERSION);
    cJSON_AddItemToObject(doc, "state", game_state_to_json(state));
    return doc;
}

char *game_state_save_json_string(const GameState *state, char *error, int error_cap) {
    if (!game_state_validate(state, error, error_cap)) {
        return NULL;
    }
    cJSON *doc = make_save_doc(state);
    char *printed = cJSON_Print(doc);
    cJSON_Delete(doc);
    if (!printed) {
        set_error(error, error_cap, "failed to print state");
        return NULL;
    }
    return printed;
}

static bool make_dir_if_needed(const char *path) {
#ifdef _WIN32
    if (_mkdir(path) == 0) {
        return true;
    }
    return errno == EEXIST;
#else
    if (mkdir(path, 0755) == 0) {
        return true;
    }
    return errno == EEXIST;
#endif
}

static bool ensure_parent_dirs(const char *path, char *error, int error_cap) {
    char temp[GAME_STATE_PATH_MAX];
    if (!copy_text(temp, sizeof(temp), path)) {
        set_error(error, error_cap, "state path is too long");
        return false;
    }
    for (char *p = temp; *p; p++) {
        if (*p != '/' && *p != '\\') {
            continue;
        }
        if (p == temp || (*(p - 1) == ':')) {
            continue;
        }
        char saved = *p;
        *p = '\0';
        if (!make_dir_if_needed(temp)) {
            set_error(error, error_cap, "failed to create state directory");
            return false;
        }
        *p = saved;
    }
    return true;
}

static bool replace_file(const char *tmp_path, const char *path) {
#ifdef _WIN32
    return MoveFileExA(tmp_path, path, MOVEFILE_REPLACE_EXISTING | MOVEFILE_WRITE_THROUGH) != 0;
#else
    return rename(tmp_path, path) == 0;
#endif
}

bool game_state_save(const GameState *state, const char *path, char *error, int error_cap) {
    if (!path || !path[0]) {
        set_error(error, error_cap, "path is required");
        return false;
    }
    if (!game_state_validate(state, error, error_cap)) {
        return false;
    }
    if (!ensure_parent_dirs(path, error, error_cap)) {
        return false;
    }
    char *printed = game_state_save_json_string(state, error, error_cap);
    if (!printed) {
        return false;
    }
    char tmp_path[GAME_STATE_PATH_MAX];
    if (snprintf(tmp_path, sizeof(tmp_path), "%s.tmp", path) >= (int)sizeof(tmp_path)) {
        cJSON_free(printed);
        set_error(error, error_cap, "state temp path is too long");
        return false;
    }
    FILE *file = fopen(tmp_path, "wb");
    if (!file) {
        cJSON_free(printed);
        set_error(error, error_cap, "failed to open state file for write");
        return false;
    }
    size_t len = strlen(printed);
    bool ok = fwrite(printed, 1, len, file) == len;
    ok = fclose(file) == 0 && ok;
    cJSON_free(printed);
    if (!ok) {
        (void)remove(tmp_path);
        set_error(error, error_cap, "failed to write state file");
        return false;
    }
    if (!replace_file(tmp_path, path)) {
        (void)remove(tmp_path);
        set_error(error, error_cap, "failed to replace state file");
        return false;
    }
    return true;
}

static bool read_file(const char *path, char **out, char *error, int error_cap) {
    FILE *file = fopen(path, "rb");
    if (!file) {
        set_error(error, error_cap, "failed to open state file for read");
        return false;
    }
    if (fseek(file, 0, SEEK_END) != 0) {
        fclose(file);
        set_error(error, error_cap, "failed to seek state file");
        return false;
    }
    long size = ftell(file);
    if (size < 0 || size > GAME_STATE_MAX_FILE_BYTES) {
        fclose(file);
        set_error(error, error_cap, "state file too large");
        return false;
    }
    if (fseek(file, 0, SEEK_SET) != 0) {
        fclose(file);
        set_error(error, error_cap, "failed to rewind state file");
        return false;
    }
    char *data = (char *)malloc((size_t)size + 1U);
    if (!data) {
        fclose(file);
        set_error(error, error_cap, "failed to allocate state file buffer");
        return false;
    }
    size_t read_size = fread(data, 1, (size_t)size, file);
    fclose(file);
    if (read_size != (size_t)size) {
        free(data);
        set_error(error, error_cap, "failed to read state file");
        return false;
    }
    data[size] = '\0';
    *out = data;
    return true;
}

static bool migrate_json(cJSON *state, int from_version, char *error, int error_cap) {
    int version = from_version;
    while (version < GAME_STATE_VERSION) {
        bool advanced = false;
        for (size_t i = 0; i < sizeof(k_migrations) / sizeof(k_migrations[0]); i++) {
            const GameStateMigration *migration = &k_migrations[i];
            if (migration->from_version == version) {
                if (!migration->fn(state, error, error_cap)) {
                    return false;
                }
                version = migration->to_version;
                advanced = true;
                break;
            }
        }
        if (!advanced) {
            set_error(error, error_cap, "missing state migration");
            return false;
        }
    }
    return true;
}

static bool game_state_load_doc(GameState *state, cJSON *doc, char *error, int error_cap) {
    cJSON *state_json = doc;
    int version = 0;
    const cJSON *schema = object_item(doc, "schema");
    const cJSON *document = object_item(doc, "document");
    const cJSON *version_json = object_item(doc, "version");
    const cJSON *wrapped_state = object_item(doc, "state");
    if (schema || version_json || wrapped_state) {
        if (!cJSON_IsString(schema) || strcmp(schema->valuestring, GAME_STATE_SCHEMA_ID) != 0) {
            set_error(error, error_cap, "state schema mismatch");
            return false;
        }
        if (document && (!cJSON_IsString(document) || strcmp(document->valuestring, GAME_STATE_DOCUMENT) != 0)) {
            set_error(error, error_cap, "state document mismatch");
            return false;
        }
        if (!cJSON_IsNumber(version_json) || !cJSON_IsObject(wrapped_state)) {
            set_error(error, error_cap, "invalid state envelope");
            return false;
        }
        if (version_json->valuedouble != (double)(int)version_json->valuedouble) {
            set_error(error, error_cap, "state version must be an integer");
            return false;
        }
        version = (int)version_json->valuedouble;
        state_json = (cJSON *)wrapped_state;
    }

    bool ok = true;
    if (version > GAME_STATE_VERSION) {
        set_error(error, error_cap, "state version is newer than runtime");
        ok = false;
    }
    if (ok && version < GAME_STATE_VERSION) {
        ok = migrate_json(state_json, version, error, error_cap);
    }
    GameState next;
    if (ok) {
        ok = game_state_from_json(&next, state_json, error, error_cap);
    }
    if (!ok) {
        return false;
    }
    GameState old = *state;
    *state = next;
    if (!notify_changed("*", error, error_cap)) {
        *state = old;
        return false;
    }
    if (state == &g_game_state) {
        game_state_clear_dirty();
    }
    return true;
}

bool game_state_load_json_string(GameState *state, const char *data, char *error, int error_cap) {
    if (!data || !data[0]) {
        set_error(error, error_cap, "state json string is empty");
        return false;
    }
    cJSON *doc = cJSON_Parse(data);
    if (!doc) {
        set_error(error, error_cap, "invalid state json");
        return false;
    }
    bool ok = game_state_load_doc(state, doc, error, error_cap);
    cJSON_Delete(doc);
    return ok;
}

bool game_state_load(GameState *state, const char *path, char *error, int error_cap) {
    char *data = NULL;
    if (!read_file(path, &data, error, error_cap)) {
        return false;
    }
    bool ok = game_state_load_json_string(state, data, error, error_cap);
    free(data);
    return ok;
}

bool game_state_reset(GameState *state, char *error, int error_cap) {
    GameState old = *state;
    GameState next;
    game_state_init_defaults(&next);
    if (!game_state_validate(&next, error, error_cap)) {
        return false;
    }
    *state = next;
    if (!notify_changed("*", error, error_cap)) {
        *state = old;
        return false;
    }
    if (state == &g_game_state) {
        game_state_mark_dirty();
    }
    return true;
}
