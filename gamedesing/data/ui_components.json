{
  "version": "0.1",
  "target": "p0_web_mobile",
  "rules": {
    "mobileFirst": true,
    "allRepeatedUiIsComponent": true,
    "stretchableFramesUseSlice9": true,
    "noHoverOnlyInteractions": true,
    "minTapTargetPx": 48,
    "primaryActionMinHeightPx": 72,
    "bottomTabMinHeightPx": 56
  },
  "slice9": {
    "button": { "sourceSize": [192, 96], "border": 24 },
    "panel": { "sourceSize": [256, 256], "border": 32 },
    "card": { "sourceSize": [256, 160], "border": 28 },
    "modal": { "sourceSize": [320, 240], "border": 36 },
    "badge": { "sourceSize": [160, 88], "border": 24 },
    "pill": { "sourceSize": [160, 72], "border": 22 },
    "tab": { "sourceSize": [128, 80], "border": 22 },
    "progress": { "sourceSize": [256, 40], "border": 16 }
  },
  "components": [
    {
      "id": "PrimaryButton",
      "asset": "ui_button_primary_9s",
      "slice9": "button",
      "minSize": [240, 72],
      "states": ["normal", "pressed", "disabled", "new", "active"],
      "uses": ["do67", "claim_reward", "event_choice"]
    },
    {
      "id": "Panel",
      "asset": "ui_panel_dark_9s",
      "slice9": "panel",
      "minSize": [280, 120],
      "states": ["normal", "disabled"],
      "uses": ["screen_section", "phone_frame_content"]
    },
    {
      "id": "Card",
      "asset": "ui_card_default_9s",
      "slice9": "card",
      "minSize": [156, 96],
      "states": ["normal", "affordable", "locked", "active", "completed", "newly_unlocked"],
      "uses": ["upgrade", "district", "deal", "training", "housing", "transport"]
    },
    {
      "id": "Modal",
      "asset": "ui_modal_9s",
      "slice9": "modal",
      "minSize": [320, 240],
      "states": ["normal"],
      "uses": ["event_modal", "offline_modal", "mini_final"]
    },
    {
      "id": "PowerBadge",
      "asset": "ui_badge_power_9s",
      "slice9": "badge",
      "minSize": [96, 56],
      "states": ["normal", "flash", "changed"],
      "uses": ["hero_power_label", "milestone", "enemy_power_label"]
    },
    {
      "id": "ResourcePill",
      "asset": "ui_pill_resource_9s",
      "slice9": "pill",
      "minSize": [112, 48],
      "states": ["normal", "changed"],
      "uses": ["memeCoins", "incomePerSecond", "clickPower"]
    },
    {
      "id": "BottomTab",
      "asset": "ui_tab_9s",
      "slice9": "tab",
      "minSize": [72, 56],
      "states": ["normal", "active", "new"],
      "tabs": ["city", "deals", "upgrades", "home"]
    },
    {
      "id": "ProgressBar",
      "asset": "ui_progress_frame_9s",
      "slice9": "progress",
      "minSize": [160, 18],
      "states": ["normal", "complete", "paused"],
      "uses": ["deal_timer", "skill_progress", "comfort_meter"]
    }
  ],
  "screenComposition": {
    "main": ["ResourcePill", "PowerBadge", "Panel", "PrimaryButton", "Card", "BottomTab"],
    "city": ["Panel", "Card", "BottomTab"],
    "deals": ["Panel", "Card", "ProgressBar", "PrimaryButton", "BottomTab"],
    "upgrades": ["Panel", "Card", "PowerBadge", "BottomTab"],
    "home": ["Panel", "Card", "ProgressBar", "BottomTab"],
    "event_modal": ["Modal", "PrimaryButton"],
    "offline_modal": ["Modal", "PrimaryButton"],
    "mini_final": ["Modal", "PowerBadge", "PrimaryButton"]
  }
}
