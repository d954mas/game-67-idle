{
  "version": "0.1",
  "scope": "Evidence required after P0 runtime prototype exists",
  "storageRules": {
    "temporaryEvidenceDir": "tmp",
    "finalFindingsDir": "gamedesing",
    "doNotCommitTemporaryEvidence": true
  },
  "canonicalFiles": [
    {
      "id": "build_validation_log",
      "pathPattern": "tmp/build_validation_YYYYMMDD.log",
      "containsEvidenceIds": [
        "validator_output",
        "runtime_build_log"
      ]
    },
    {
      "id": "runtime_qa_log",
      "pathPattern": "tmp/runtime_qa_YYYYMMDD.log",
      "containsEvidenceIds": [
        "runtime_test_log",
        "tap_target_audit",
        "analytics_disabled_audit"
      ]
    },
    {
      "id": "viewport_evidence_index",
      "pathPattern": "tmp/viewport_evidence_YYYYMMDD.md",
      "containsEvidenceIds": [
        "desktop_portrait_screenshot",
        "mobile_360_screenshot",
        "mobile_390_screenshot"
      ]
    },
    {
      "id": "route_rehearsal_notes",
      "pathPattern": "tmp/route_30min_rehearsal_YYYYMMDD.md",
      "containsEvidenceIds": [
        "manual_30min_route_notes"
      ]
    },
    {
      "id": "playtest_observations_jsonl",
      "pathPattern": "tmp/playtest_observations_round_01.jsonl",
      "containsEvidenceIds": [
        "playtest_observation_rows"
      ]
    }
  ],
  "evidence": [
    {
      "id": "validator_output",
      "store": "tmp",
      "requiredBefore": "developer_handoff_review",
      "proves": [
        "all_gdd_contracts_pass"
      ],
      "sourceCommand": "node gamedesing/tools/validate_all.mjs",
      "expectedResult": "14/14 scripts passed or current script count all passed"
    },
    {
      "id": "runtime_build_log",
      "store": "tmp",
      "requiredBefore": "external_playtest",
      "proves": [
        "runtime build",
        "web/mobile build launches"
      ],
      "sourceCommand": "npm run build",
      "expectedResult": "build exits 0"
    },
    {
      "id": "runtime_test_log",
      "store": "tmp",
      "requiredBefore": "external_playtest",
      "proves": [
        "runtime QA evidence",
        "smoke route works",
        "save/load/offline works"
      ],
      "sourceCommand": "npm run test",
      "expectedResult": "tests exit 0"
    },
    {
      "id": "desktop_portrait_screenshot",
      "store": "tmp",
      "requiredBefore": "external_playtest",
      "proves": [
        "real screenshots",
        "desktop portrait has no overlap"
      ],
      "viewport": "desktop_portrait_frame",
      "expectedResult": "real runtime screenshot, not fakeshots.html"
    },
    {
      "id": "mobile_360_screenshot",
      "store": "tmp",
      "requiredBefore": "external_playtest",
      "proves": [
        "real screenshots",
        "360x640 has no overflow"
      ],
      "viewport": "360x640",
      "expectedResult": "real runtime screenshot, not fakeshots.html"
    },
    {
      "id": "mobile_390_screenshot",
      "store": "tmp",
      "requiredBefore": "external_playtest",
      "proves": [
        "real screenshots",
        "390x844 has no overflow"
      ],
      "viewport": "390x844",
      "expectedResult": "real runtime screenshot, not fakeshots.html"
    },
    {
      "id": "tap_target_audit",
      "store": "tmp",
      "requiredBefore": "external_playtest",
      "proves": [
        "tap targets meet specs",
        "text sizes meet specs"
      ],
      "expectedResult": "all critical buttons/cards meet ui_flow globalRules"
    },
    {
      "id": "analytics_disabled_audit",
      "store": "tmp",
      "requiredBefore": "external_playtest",
      "proves": [
        "analytics stub disabled by default",
        "no personal payload fields"
      ],
      "expectedResult": "no network analytics calls when analyticsEnabled=false"
    },
    {
      "id": "manual_30min_route_notes",
      "store": "tmp",
      "requiredBefore": "external_playtest",
      "proves": [
        "30-minute manual route",
        "no crash/stuck state"
      ],
      "expectedResult": "active route reaches 15/67 and both final choices checked"
    },
    {
      "id": "parent_invite_copy",
      "store": "tmp",
      "requiredBefore": "external_playtest",
      "proves": [
        "parent invite evidence",
        "parent note attached"
      ],
      "expectedResult": "invite includes parent_playtest_note.md summary and reset/delete path"
    },
    {
      "id": "playtest_observation_rows",
      "store": "tmp",
      "requiredBefore": "post_playtest_analysis",
      "proves": [
        "playtest observation rows",
        "children 5-7 understand 67",
        "parents accept tone"
      ],
      "schema": "data/playtest_observation_schema.json",
      "expectedResult": "5-8 supervised sessions recorded without personal child data"
    },
    {
      "id": "playtest_review_round",
      "store": "gamedesing",
      "requiredBefore": "post_playtest_iteration",
      "proves": [
        "final findings captured",
        "balance/copy/design next changes identified"
      ],
      "expectedResult": "playtest_review_round_XX.md created from observation rows"
    }
  ],
  "handoffNoGoCoverage": [
    {
      "noGo": "runtime build",
      "evidenceIds": [
        "runtime_build_log",
        "runtime_test_log"
      ]
    },
    {
      "noGo": "real screenshots",
      "evidenceIds": [
        "desktop_portrait_screenshot",
        "mobile_360_screenshot",
        "mobile_390_screenshot"
      ]
    },
    {
      "noGo": "runtime QA evidence",
      "evidenceIds": [
        "runtime_test_log",
        "tap_target_audit",
        "analytics_disabled_audit",
        "manual_30min_route_notes"
      ]
    },
    {
      "noGo": "parent invite evidence",
      "evidenceIds": [
        "parent_invite_copy"
      ]
    },
    {
      "noGo": "playtest observation rows",
      "evidenceIds": [
        "playtest_observation_rows",
        "playtest_review_round"
      ]
    }
  ]
}
