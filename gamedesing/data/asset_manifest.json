{
  "version": "0.1",
  "target": "p0_web_mobile",
  "rules": {
    "format": "png_or_webp",
    "maxTextureSize": 2048,
    "mobileFirst": true,
    "fallbackAllowed": true,
    "style": "bright meme toy-like, readable silhouettes, no realistic hardship"
  },
  "gddSiteArt": [
    {
      "id": "generated_comeback_keyart",
      "path": "art/generated-67-comeback-keyart.png",
      "usage": "visual GDD hero and lore anchor",
      "intent": "show the lost drama clearly: 67/67 at the top, Banana and Strawberry betrayal, stripped down to 1/67"
    },
    {
      "id": "generated_gameplay_fakeshot",
      "path": "art/generated-67-gameplay-fakeshot.png",
      "usage": "visual GDD gameplay fake shot",
      "intent": "show the actual playable loop surface: 1/67 badge, big 67 gesture button, resources, jobs, upgrades, home and tabs"
    },
    {
      "id": "generated_life_sim_progression",
      "path": "art/generated-67-life-sim-progression.png",
      "usage": "visual GDD life-sim progression",
      "intent": "show growth through starter room, kiosk job, upgraded home, transport, team and mini business"
    },
    {
      "id": "generated_asset_sheet",
      "path": "art/generated-67-asset-sheet.png",
      "usage": "visual development and asset direction",
      "intent": "show reusable game art pieces: hero stages, Banana, Strawberry, 67 coin, gesture, home, transport and kiosk"
    },
    {
      "id": "runtime_composed_screen",
      "path": "assets/generated/runtime_composed_screen.png",
      "usage": "runtime art proof",
      "intent": "show a game screen composed from separate generated runtime assets, not a fake shot"
    },
    {
      "id": "runtime_asset_pack_preview",
      "path": "assets/generated/runtime_asset_pack_preview.png",
      "usage": "runtime art bible preview",
      "intent": "show game-ready generated PNGs for characters, UI sprites and backgrounds"
    },
    {
      "id": "life_sim_progression_board",
      "path": "art/gdd-life-sim-progression.png",
      "usage": "visual GDD progression section",
      "intent": "show life-sim growth through room, city, deal, transport, base and 67/67 dream"
    },
    {
      "id": "game_fakeshot_board",
      "path": "art/gdd-game-fakeshot-board.png",
      "usage": "visual GDD fake shots section",
      "intent": "show four game-like P0 screens: main, city, deals, home/transport"
    },
    {
      "id": "ui_kit_slice9_board",
      "path": "art/gdd-ui-kit-slice9-board.png",
      "usage": "visual GDD UI bible section",
      "intent": "show reusable component style for buttons, panels, cards, badges, tabs and progress bars"
    }
  ],
