{
  "version": 1,
  "scope": "first_playable_slice",
  "screens": [
    {
      "id": "province_map",
      "label": "Province Map",
      "purpose": "Choose the next destination and show adventure direction.",
      "primary_actions": ["travel_old_road"],
      "visible_state": ["gold", "supplies", "health", "resolve", "active_quest"],
      "next_screens": ["encounter_view"]
    },
    {
      "id": "encounter_view",
      "label": "Encounter View",
      "purpose": "Resolve first-person/illustrated location actions.",
      "primary_actions": ["search_standing_stones", "approach_ruins", "fight_enemy"],
      "visible_state": ["health", "resolve", "quest_objective", "recent_result", "camp_availability"],
      "next_screens": ["combat_panel", "loot_result", "camp"]
    },
    {
      "id": "combat_panel",
      "label": "Combat Panel",
      "purpose": "Simple turn-based fight options.",
      "primary_actions": ["attack", "defend", "use_item", "skill_check"],
      "visible_state": ["health", "resolve", "enemy_health", "turn_hint"],
      "next_screens": ["loot_result", "encounter_view"]
    },
    {
      "id": "loot_result",
      "label": "Loot Result",
      "purpose": "Show reward, comparison, and next decision.",
      "primary_actions": ["equip", "take_all", "continue"],
      "visible_state": ["loot_items", "stat_delta", "dragon_omen_delta"],
      "next_screens": ["encounter_view", "province_map", "camp"]
    },
    {
      "id": "camp",
      "label": "Safe Camp",
      "purpose": "Rest, craft, level, talk, prepare.",
      "primary_actions": ["rest", "craft", "level_up", "talk_companion", "inspect_dragon_relic", "leave_camp"],
      "visible_state": ["health", "resolve", "supplies", "herbs", "companion_notice", "dragon_relic_state"],
      "blocked_states": ["unsafe_location", "insufficient_supplies_for_full_rest"],
      "next_screens": ["province_map", "inventory"]
    },
    {
      "id": "inventory",
      "label": "Inventory",
      "purpose": "Compare gear and consumables.",
      "primary_actions": ["equip", "compare", "use_item", "back"],
      "visible_state": ["equipped_weapon", "equipped_armor", "consumables", "stat_delta"],
      "next_screens": ["camp", "encounter_view"]
    }
  ],
  "first_minute_path": [
    "province_map",
    "encounter_view",
    "loot_result"
  ],
  "first_five_minute_path": [
    "province_map",
    "encounter_view",
    "combat_panel",
    "loot_result",
    "camp",
    "province_map"
  ],
  "fake_shot_states": [
    {
      "id": "map_ready",
      "screen": "province_map",
      "must_show": ["active_quest", "old_road_node", "locked_hunter_ford_node", "top_stats"]
    },
    {
      "id": "ruins_encounter",
      "screen": "encounter_view",
      "must_show": ["first_person_ruins", "search_action", "health_resolve", "camp_locked_or_safe_hint", "dragon_mark_hint"]
    },
    {
      "id": "camp_unlocked",
      "screen": "camp",
      "must_show": ["campfire_scene", "rest_craft_talk_actions", "supplies_herbs", "companion_notice", "dragon_relic"]
    }
  ]
}
