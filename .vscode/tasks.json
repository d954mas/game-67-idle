{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "CMake: configure native debug",
            "type": "shell",
            "command": "cmake --preset native-debug",
            "problemMatcher": []
        },
        {
            "label": "Build: native debug",
            "type": "shell",
            "command": "cmake --build --preset native-debug --target game_seed",
            "dependsOn": "CMake: configure native debug",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "Run: native debug",
            "type": "shell",
            "command": "${workspaceFolder}/build/game_seed/native-debug/game_seed.exe",
            "dependsOn": "Build: native debug",
            "problemMatcher": []
        },
        {
            "label": "Run: native debug + devapi",
            "type": "shell",
            "command": "${workspaceFolder}/build/game_seed/native-debug/game_seed.exe --devapi 9123",
            "dependsOn": "Build: native debug",
            "problemMatcher": []
        },
        {
            "label": "DevAPI: smoke test",
            "type": "shell",
            "command": "py -3.12 tools/devapi/smoke.py 9123",
            "dependsOn": "Build: native debug",
            "problemMatcher": []
        },
        {
            "label": "Capture: desktop screenshot",
            "type": "shell",
            "command": "powershell -ExecutionPolicy Bypass -File tools/devapi/capture_screen.ps1 build/captures/screenshot.png",
            "problemMatcher": []
        },
        {
            "label": "Capture: desktop recording",
            "type": "shell",
            "command": "powershell -ExecutionPolicy Bypass -File tools/devapi/record_screen_ffmpeg.ps1 build/captures/gameplay.mp4",
            "problemMatcher": []
        },
        {
            "label": "CMake: configure native release",
            "type": "shell",
            "command": "cmake --preset native-release",
            "problemMatcher": []
        },
        {
            "label": "Build: native release",
            "type": "shell",
            "command": "cmake --build --preset native-release --target game_seed",
            "dependsOn": "CMake: configure native release",
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "Release: native PC",
            "dependsOn": "Build: native release",
            "group": "build",
            "problemMatcher": []
        },
        {
            "label": "CMake: configure wasm debug",
            "type": "shell",
            "command": "emcmake.bat cmake --preset wasm-debug",
            "problemMatcher": []
        },
        {
            "label": "Build: wasm debug",
            "type": "shell",
            "command": "cmake --build --preset wasm-debug --target game_seed",
            "dependsOn": "CMake: configure wasm debug",
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "Web: serve debug",
            "type": "shell",
            "command": "powershell -ExecutionPolicy Bypass -File scripts/serve-web.ps1 build/game_seed/wasm-debug 8080",
            "dependsOn": "Build: wasm debug",
            "isBackground": true,
            "problemMatcher": {
                "pattern": {
                    "regexp": "."
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "Serving .* at http://localhost:8080/",
                    "endsPattern": "Serving .* at http://localhost:8080/"
                }
            }
        },
        {
            "label": "CMake: configure wasm release",
            "type": "shell",
            "command": "emcmake.bat cmake --preset wasm-release",
            "problemMatcher": []
        },
        {
            "label": "Release: web",
            "type": "shell",
            "command": "cmake --build --preset wasm-release --target game_seed",
            "dependsOn": "CMake: configure wasm release",
            "group": "build",
            "problemMatcher": ["$gcc"]
        },
        {
            "label": "Web: serve release",
            "type": "shell",
            "command": "powershell -ExecutionPolicy Bypass -File scripts/serve-web.ps1 build/game_seed/wasm-release 8081",
            "dependsOn": "Release: web",
            "isBackground": true,
            "problemMatcher": {
                "pattern": {
                    "regexp": "."
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": "Serving .* at http://localhost:8081/",
                    "endsPattern": "Serving .* at http://localhost:8081/"
                }
            }
        },
        {
            "label": "Release: all",
            "dependsOrder": "sequence",
            "dependsOn": [
                "Release: native PC",
                "Release: web"
            ],
            "problemMatcher": []
        },
        {
            "label": "Tasks: serve board",
            "type": "shell",
            "command": "node tools/taskboard/server.mjs",
            "isBackground": true,
            "problemMatcher": []
        }
    ]
}
