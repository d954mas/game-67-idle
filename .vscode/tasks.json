{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Game: rb-dark-rpg: configure native debug",
      "type": "shell",
      "command": "cmake",
      "args": [
        "-S",
        "${workspaceFolder}/games/rb-dark-rpg",
        "-B",
        "${workspaceFolder}/games/rb-dark-rpg/build/native-debug",
        "-G",
        "Ninja",
        "-DCMAKE_C_COMPILER=clang",
        "-DCMAKE_BUILD_TYPE=Debug"
      ],
      "problemMatcher": []
    },
    {
      "label": "Game: rb-dark-rpg: build packs native debug",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "${workspaceFolder}/games/rb-dark-rpg/build/native-debug",
        "--target",
        "game_asset_packs"
      ],
      "dependsOn": "Game: rb-dark-rpg: configure native debug",
      "problemMatcher": [
        "$gcc"
      ],
      "group": "build"
    },
