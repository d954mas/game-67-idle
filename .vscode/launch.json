{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Native Debug (PC)",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/game_seed/native-debug/game_seed.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "console": "integratedTerminal",
            "preLaunchTask": "Build: native debug"
        },
        {
            "name": "Native Debug + DevAPI (PC)",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/game_seed/native-debug/game_seed.exe",
            "args": ["--devapi", "9123"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "console": "integratedTerminal",
            "preLaunchTask": "Build: native debug"
        },
        {
            "name": "Native Release (PC)",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/game_seed/native-release/game_seed.exe",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "console": "integratedTerminal",
            "preLaunchTask": "Release: native PC"
        },
        {
            "name": "Web Debug (Chrome)",
            "type": "pwa-chrome",
            "request": "launch",
            "url": "http://localhost:8080/index.html",
            "webRoot": "${workspaceFolder}/build/game_seed/wasm-debug",
            "preLaunchTask": "Web: serve debug"
        },
        {
            "name": "Web Release (Chrome)",
            "type": "pwa-chrome",
            "request": "launch",
            "url": "http://localhost:8081/index.html",
            "webRoot": "${workspaceFolder}/build/game_seed/wasm-release",
            "preLaunchTask": "Web: serve release"
        },
        {
            "name": "Build Pack Debug",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/game_seed/native-debug/build_67_world_packs.exe",
            "args": ["${workspaceFolder}/build/game_seed/67-world-packs"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "console": "integratedTerminal",
            "preLaunchTask": "Build: pack builder debug"
        },
        {
            "name": "Build Pack Release",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/game_seed/native-release/build_67_world_packs.exe",
            "args": ["${workspaceFolder}/build/game_seed/67-world-packs"],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "console": "integratedTerminal",
            "preLaunchTask": "Build: pack builder release"
        }
    ]
}
