{
  "schema": "ai_studio.feature.v1",
  "id": "game-state",
  "title": "Game State",
  "status": "reusable",
  "kind": "gameplay-infrastructure",
  "summary": "Schema-first generated game state with JSON save/load and DevAPI adapters.",
  "copy_model": "manual-copy",
  "owners": [
    "features/game-state"
  ],
  "dependencies": [
    "Python 3.12",
    "templates/template/state/game_state.schema.json or a game-local state schema",
    "template or game C runtime using generated GameState files",
    "Neotolis engine public APIs for runtime and DevAPI integration"
  ],
  "flags": {
    "feature": "FEATURE_GAME_STATE",
    "devapi": "GAME_DEVAPI_ENABLED",
    "devapi_condition": "FEATURE_GAME_STATE && GAME_DEVAPI_ENABLED"
  },
  "commands": {
    "generate": "py -3.12 features/game-state/scripts/generate_state.py",
    "test": "py -3.12 features/game-state/scripts/generate_state_test.py"
  },
  "manuals": {
    "install": "features/game-state/INSTALL.md",
    "contract": "features/game-state/references/contract.md",
    "workflow": "features/game-state/references/workflow.md",
    "review": "features/game-state/references/review.md"
  },
  "outputs": [
    "game_state.h",
    "game_state.c",
    "game_state_devapi.c",
    "game_state_schema.gen.h"
  ],
  "default_template": {
    "schema": "templates/template/state/game_state.schema.json",
    "generated_dir": "templates/template/build/<config>/generated/game-state",
    "runtime_sources": [
      "templates/template/src/game_state_json.c",
      "templates/template/src/game_state_json.h",
      "templates/template/src/game_storage.c",
      "templates/template/src/game_storage.h",
      "templates/template/src/game_save.c",
      "templates/template/src/game_save.h",
      "templates/template/src/game_fragment.c"
    ]
  }
}
