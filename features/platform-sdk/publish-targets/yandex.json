{
  "schema": "ai_studio.publish_target.v1",
  "target": "yandex",
  "platform_sdk": "yandex",
  "required_files": [
    "index.html",
    "game.js",
    "game.wasm",
    "assets/game.ntpack",
    "runtime-build.json",
    "platform-sdk.js",
    "platform-sdk-core.js",
    "platform-sdk-adapter.js"
  ],
  "zip_layout": "Yandex archive root: index.html, game.js, game.wasm, runtime-build.json, platform-sdk*.js, and assets/game.ntpack. Portal-provided /sdk.js is not bundled.",
  "metadata": {
    "portal": "Yandex Games",
    "requires_account": true,
    "sdk_loader": "/sdk.js",
    "orientation": "game-owned",
    "viewport": "responsive canvas"
  },
  "sdk_policy": {
    "adapter": "yandex",
    "sdk_url": "/sdk.js",
    "load_policy": "platform-sdk-adapter.js loads /sdk.js during selected web backend init; no template HTML injection.",
    "ads": "showFullscreenAdv for interstitial, showRewardedVideo for rewarded",
    "storage": "player data through wrapper only",
    "debug_ui": "forbidden in release artifact",
    "forbidden_markers": [
      "https://game-cdn.poki.com/scripts/v2/poki-sdk.js",
      "https://bridge.playgama.com/v1/stable/playgama-bridge.js",
      "Show interstitial ad",
      "Show rewarded ad",
      "debug_test"
    ]
  },
  "validation_command": "node features/platform-sdk/scripts/artifact_tools.mjs inspect --target yandex --artifact <artifact-dir>"
}
