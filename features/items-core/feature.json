{
  "schema": "ai_studio.feature.v1",
  "id": "items-core",
  "version": "1.8.0",
  "title": "Items Core",
  "status": "reusable",
  "kind": "gameplay-infrastructure",
  "summary": "In-place L1 module: deterministic Lua item declarations, catalog codegen, ownership operations, and read-only tooling.",
  "copy_model": "in-place",
  "layer": "L1",
  "owners": [
    "features/items-core"
  ],
  "dependencies": [
    "Python 3.12",
    "Lupa 2.8 using its bundled lupa.lua54 backend (installed by the AI Studio Python environment)",
    "templates/template/content/items.json + content/item_fields.schema.json (or a game-local items catalog)",
    "template or game C runtime using the generated items_catalog.gen.{h,c} + the generated items save fragment (features/game-state)",
    "the consuming game's own src/features/items/reason_tags.h (closed reason-verb list, resolved via the game's include path)"
  ],
  "commands": {
    "generate": "node ai_studio/dev_environment/python_run.mjs features/items-core/scripts/generate_items_catalog.py",
    "list": "node ai_studio/dev_environment/python_run.mjs features/items-core/scripts/items_ops.py list",
    "validate": "node ai_studio/dev_environment/python_run.mjs features/items-core/scripts/items_ops.py validate",
    "schema": "node ai_studio/dev_environment/python_run.mjs features/items-core/scripts/items_ops.py schema",
    "upgrade_receipt": "node ai_studio/dev_environment/python_run.mjs features/items-core/scripts/items_ops.py upgrade-receipt",
    "validate_evaluation_receipt": "node ai_studio/dev_environment/python_run.mjs features/items-core/scripts/items_ops.py validate-evaluation-receipt",
    "seal_evaluation_receipt": "node ai_studio/dev_environment/python_run.mjs features/items-core/scripts/items_ops.py seal-evaluation-receipt",
    "test": "node ai_studio/dev_environment/python_run.mjs features/items-core/scripts/items_ops_test.py",
    "api_proof": "node ai_studio/dev_environment/python_run.mjs features/items-core/scripts/generate_items_api_proof.py --snapshot features/items-core/tests/fixtures/items_api_weapon_proof.json --out-dir <build-dir>",
    "api_proof_test": "node ai_studio/dev_environment/python_run.mjs features/items-core/scripts/generate_items_api_proof_test.py",
    "lua_evaluate": "node ai_studio/dev_environment/python_run.mjs features/items-core/scripts/items_lua_sandbox.py evaluate --root <game-root> --manifest <game-root>/items.lua.json",
    "lua_sandbox_test": "node ai_studio/dev_environment/python_run.mjs features/items-core/scripts/items_lua_sandbox_test.py",
    "snapshot_build": "node ai_studio/dev_environment/python_run.mjs features/items-core/scripts/items_snapshot.py build --evaluation <evaluation.json> --out <snapshot.json>",
    "snapshot_query": "node ai_studio/dev_environment/python_run.mjs features/items-core/scripts/items_snapshot.py query --snapshot <snapshot.json> --item <item-id>",
    "snapshot_chart": "node ai_studio/dev_environment/python_run.mjs features/items-core/scripts/items_snapshot.py chart --snapshot <snapshot.json> --item <item-id> --field <field>",
    "snapshot_requirements": "node ai_studio/dev_environment/python_run.mjs features/items-core/scripts/items_snapshot.py requirements --snapshot <snapshot.json>",
    "snapshot_diff": "node ai_studio/dev_environment/python_run.mjs features/items-core/scripts/items_snapshot.py diff --before <old-snapshot.json> --after <new-snapshot.json>",
    "snapshot_test": "node ai_studio/dev_environment/python_run.mjs features/items-core/scripts/items_snapshot_test.py",
    "runtime_package": "node ai_studio/dev_environment/python_run.mjs features/items-core/scripts/items_runtime_package.py build --snapshot <snapshot.json> --out <items.catalog> --header-out <items_catalog_abi.gen.h>",
    "runtime_package_test": "node ai_studio/dev_environment/python_run.mjs features/items-core/scripts/items_runtime_package_test.py"
  },
  "manuals": {
    "install": "features/items-core/INSTALL.md",
    "typed_api_proof": "features/items-core/docs/items_lua_schema_api_contract_2026-07-10.md",
    "lua_authoring_contract": "features/items-core/docs/items_lua_single_source_concept_2026-07-10.md"
  },
  "outputs": [
    "items_catalog.gen.h",
    "items_catalog.gen.c",
    "items_game.gen.h",
    "items_game.internal.gen.h",
    "items_game.gen.c",
    "items_game.luau",
    "items.lua.evaluation.v1 JSON",
    "items.snapshot.v1 JSON",
    "items.snapshot.chart.v1 JSON",
    "items.snapshot.requirements.v1 JSON",
    "items.snapshot.diff.v1 JSON",
    "items/catalog compact runtime package v1",
    "items_catalog_abi.gen.h"
  ],
  "registers": {
    "note": "Describes the EXISTING wiring in templates/template/CMakeLists.txt (target_sources/ctest) -- items-core is an in-place module (precedent features/game-state), not an install-script target. This section documents the consuming game's provisioning, it does not perform it.",
    "target_sources": [
      "${ITEMS_CORE_SRC}/items_catalog.c",
      "${ITEMS_CORE_SRC}/items_containers.c",
      "${ITEMS_CORE_SRC}/items_reconcile.c"
    ],
    "include_dirs": [
      "${ITEMS_CORE_INC}"
    ],
    "ctest_targets": [
      "test_items_catalog",
      "test_items_fragment",
      "items_ops_validate",
      "items_ops_test",
      "test_items_api_core_only",
      "test_items_api",
      "test_items_runtime_package",
      "generate_items_api_proof_test"
    ]
  },
  "default_template": {
    "catalog": "templates/template/content/items.json",
    "field_schema": "templates/template/content/item_fields.schema.json",
    "lock": "templates/template/content/items.lock.json",
    "state_schema": "templates/template/state/items.schema.json",
    "generated_dir": "templates/template/src/generated",
    "game_side_sources": [
      "templates/template/src/features/items/reason_tags.h",
      "templates/template/src/features/items/items_bootstrap.c"
    ]
  }
}
