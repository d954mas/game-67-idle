{
  "schema": "game_seed.items",
  "schema_version": 2,
  "fragment": "items",
  "version": 1,
  "string_max": 128,
  "reserved": ["owned"],
  "hooks": { "reconcile": true },
  "enums": {
    "ContainerPolicy": ["generic", "currency_only", "equipment"]
  },
  "types": {
    "ItemEntry": {
      "kind": "object",
      "reserved": ["container", "container_id", "entry_key", "key"],
      "fields": {
        "entry_id": { "type": "u32", "default": 1, "min": 1, "max": 4294967294 },
        "slot": { "type": "u32", "default": 0, "min": 0, "max": 1023 },
        "def_id": { "type": "string", "max_length": 127 },
        "count": { "type": "i64", "default": 0, "min": 0, "max": 9000000000000000000 },
        "level": { "type": "int", "default": 1, "min": 1, "max": 9999 },
        "durability": { "type": "float", "default": 1, "min": 0, "max": 1 },
        "quarantined": { "type": "bool", "default": false }
      }
    },
    "ItemContainer": {
      "kind": "object",
      "reserved": ["entry_keys", "id", "name"],
      "fields": {
        "container_id": { "type": "u32", "default": 1, "min": 1, "max": 4294967294 },
        "capacity": { "type": "u32", "default": 0, "min": 0, "max": 1024 },
        "policy": { "type": "enum", "enum": "ContainerPolicy", "default": "generic" },
        "entries": {
          "type": "list<ItemEntry>",
          "max_count": 1024,
          "order_by": ["slot", "entry_id"]
        }
      }
    }
  },
  "fields": {
    "last_container_id": { "type": "u32", "default": 0, "min": 0, "max": 4294967294 },
    "last_entry_id": { "type": "u32", "default": 0, "min": 0, "max": 4294967294 },
    "containers": {
      "type": "list<ItemContainer>",
      "max_count": 128,
      "order_by": ["container_id"]
    }
  },
  "events": {
    "txn": {
      "fields": {
        "op":              { "type": "string" },
        "def_id":          { "type": "string" },
        "container":       { "type": "string" },
        "entry_key":       { "type": "string" },
        "requested_delta": { "type": "i64" },
        "applied_delta":   { "type": "i64" },
        "before_count":    { "type": "i64" },
        "after_count":     { "type": "i64" },
        "reason":          { "type": "string" }
      }
    },
    "move": {
      "fields": {
        "def_id":          { "type": "string" },
        "entry_key":       { "type": "string" },
        "from_container":  { "type": "string" },
        "to_container":    { "type": "string" },
        "requested_count": { "type": "i64" },
        "moved_count":     { "type": "i64" },
        "reason":          { "type": "string" }
      }
    }
  }
}
