tmp/
.serena/
.cache/
.pytest_cache/
# Root-level native/CMake build output.
build/
# Repo-local studio Python venv for the image asset tools (created by
# ai_studio/assets/tools/image/_bridge/setup_python.mjs). Never committed.
.venv/
.vs/
.vscode/.cmake/
.claude/settings.local.json
compile_commands.json
*.user
*.suo
*.ntpack
__pycache__/
*.pyc

# Builder scratch for asset packs
*.png.ppm

# Generated architecture map report: served live via /api/architecture-validation.
# The validate_map.mjs CLI still writes it locally for offline inspection.
ai_studio/architecture_map/validation-report.json

# Per-machine Studio config override for local paths and tool roots. Only the
# committed ai_studio/studio.config.json defaults are tracked.
ai_studio/studio.config.local.json

# Local/private game workspace mounts. Public games stay in the tracked catalog;
# private commercial game ids, remotes, aliases, and roots must stay local.
ai_studio/workspace/catalog.local.json

# Closed Taskboard bodies are cold history. Pending Markdown stays local until
# an explicit ZIP seal; sealed ZIP batches remain trackable.
ai_studio/taskboard/items/archive/pending/
games/*/.ai_studio/taskboard/items/archive/pending/

# Local Canvas project working copies. The committed studio config keeps the
# canonical projects root outside the repo.
ai_studio/assets/canvas/projects/

# Raw Canvas project folders must not enter game/template repositories. Canvas
# ownership is stored in each shared-root project.json instead.
games/*/.ai_studio/canvas/
templates/*/.ai_studio/canvas/

# Game-local evidence can contain private screenshots, reports, and absolute
# local paths. Promote sanitized artifacts through normal assets/design folders.
games/*/.ai_studio/evidence/*
!games/*/.ai_studio/evidence/.gitignore
!games/*/.ai_studio/evidence/README.md

# Restricted paid/licensed asset binaries: never commit to an open repo.
# Only catalog/license metadata is committed; binaries live locally and in the
# private library. See ai_studio/assets/licenses/.
# Per-game: matches <game>/assets/restricted/ in any game folder.
**/assets/restricted/
**/assets/_incoming/
**/assets/_rejected/

templates/*/build/
templates/*/src/generated/
games/*/build/
games/*/src/generated/

# Browser automation scratch/profile files can contain cookies, history, local
# storage, and screenshots.
.playwright-cli/
chrome-cdp-profile/
web_browser_console.txt
web_browser_shot.png
web_launch.txt
