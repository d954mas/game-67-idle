{
    "version": 6,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 25,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "native-debug",
            "displayName": "Native Debug",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/_cmake/native-debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_C_STANDARD": "17",
                "CMAKE_C_STANDARD_REQUIRED": "ON",
                "CMAKE_C_COMPILER": "clang",
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
            }
        },
        {
            "name": "native-release",
            "displayName": "Native Release",
            "inherits": "native-debug",
            "binaryDir": "${sourceDir}/build/_cmake/native-release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "native-debug-closed-prototypes",
            "displayName": "Native Debug (Closed Prototypes)",
            "inherits": "native-debug",
            "binaryDir": "${sourceDir}/build/_cmake/native-debug-closed-prototypes",
            "cacheVariables": {
                "GAME_CLOSED_PROTOTYPES_ENABLED": "ON"
            }
        },
        {
            "name": "wasm-debug",
            "displayName": "WASM Debug",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/_cmake/wasm-debug",
            "toolchainFile": "$env{EMSDK}/upstream/emscripten/cmake/Modules/Platform/Emscripten.cmake",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_C_STANDARD": "17",
                "CMAKE_C_STANDARD_REQUIRED": "ON"
            }
        },
        {
            "name": "wasm-release",
            "displayName": "WASM Release",
            "inherits": "wasm-debug",
            "binaryDir": "${sourceDir}/build/_cmake/wasm-release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "wasm-qa",
            "displayName": "WASM QA",
            "inherits": "wasm-debug",
            "binaryDir": "${sourceDir}/build/_cmake/wasm-qa",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "MinSizeRel",
                "NT_WASM_QA": "ON"
            }
        },
        {
            "name": "wasm-debug-paired",
            "displayName": "WASM Debug Paired",
            "inherits": "wasm-debug",
            "binaryDir": "${sourceDir}/build/_cmake/wasm-debug-paired",
            "cacheVariables": {
                "NT_WASM_SIMD_WASM_PATH": "index_simd.wasm"
            }
        },
        {
            "name": "wasm-debug-simd",
            "displayName": "WASM Debug SIMD",
            "inherits": "wasm-debug",
            "binaryDir": "${sourceDir}/build/_cmake/wasm-debug-simd",
            "cacheVariables": {
                "NT_WASM_ENABLE_SIMD": "ON"
            }
        },
        {
            "name": "wasm-release-paired",
            "displayName": "WASM Release Paired",
            "inherits": "wasm-release",
            "binaryDir": "${sourceDir}/build/_cmake/wasm-release-paired",
            "cacheVariables": {
                "NT_WASM_SIMD_WASM_PATH": "index_simd.wasm"
            }
        },
        {
            "name": "wasm-release-simd",
            "displayName": "WASM Release SIMD",
            "inherits": "wasm-release",
            "binaryDir": "${sourceDir}/build/_cmake/wasm-release-simd",
            "cacheVariables": {
                "NT_WASM_ENABLE_SIMD": "ON"
            }
        },
        {
            "name": "wasm-analysis",
            "displayName": "WASM Analysis",
            "inherits": "wasm-release",
            "binaryDir": "${sourceDir}/build/_cmake/wasm-analysis",
            "cacheVariables": {
                "NT_WASM_ANALYSIS": "ON"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "native-debug",
            "displayName": "Build native debug",
            "configurePreset": "native-debug",
            "targets": ["game_seed"]
        },
        {
            "name": "native-release",
            "displayName": "Build native release",
            "configurePreset": "native-release",
            "targets": ["game_seed"]
        },
        {
            "name": "native-debug-closed-prototypes",
            "displayName": "Build native debug closed prototypes",
            "configurePreset": "native-debug-closed-prototypes",
            "targets": ["game_seed"]
        },
        {
            "name": "wasm-debug",
            "displayName": "Build WASM debug",
            "configurePreset": "wasm-debug",
            "targets": ["game_seed"]
        },
        {
            "name": "wasm-release",
            "displayName": "Build WASM release",
            "configurePreset": "wasm-release",
            "targets": ["game_seed"]
        },
        {
            "name": "wasm-qa",
            "displayName": "Build WASM QA",
            "configurePreset": "wasm-qa",
            "targets": ["game_seed"]
        },
        {
            "name": "wasm-debug-paired",
            "configurePreset": "wasm-debug-paired",
            "targets": ["game_seed"]
        },
        {
            "name": "wasm-debug-simd",
            "configurePreset": "wasm-debug-simd",
            "targets": ["game_seed"]
        },
        {
            "name": "wasm-release-paired",
            "configurePreset": "wasm-release-paired",
            "targets": ["game_seed"]
        },
        {
            "name": "wasm-release-simd",
            "configurePreset": "wasm-release-simd",
            "targets": ["game_seed"]
        },
        {
            "name": "wasm-analysis",
            "configurePreset": "wasm-analysis",
            "targets": ["game_seed"]
        }
    ]
}
