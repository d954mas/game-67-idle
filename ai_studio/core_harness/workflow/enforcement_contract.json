{
  "schema": "ai_studio.enforcement.v1",
  "classifications": [
    "host-enforced",
    "repository-validator-enforced",
    "process convention"
  ],
  "rules": [
    {
      "id": "codex-role-settings",
      "classification": "host-enforced",
      "proof_kind": "runtime-observed",
      "claim": "Codex owns loading project role settings; a post-restart native rollout smoke observes the applied role and model.",
      "sources": [
        ".codex/agents/README.md",
        ".codex/agents/fast-worker.toml",
        ".codex/agents/deep-reasoner.toml",
        ".codex/agents/coding-worker.toml",
        ".codex/agents/researcher.toml"
      ],
      "proof": [
        "ai_studio/core_harness/validation/agent_role_smoke.mjs",
        "ai_studio/core_harness/validation/tests/agent_role_smoke.test.mjs"
      ]
    },
    {
      "id": "codex-agent-limits",
      "classification": "host-enforced",
      "proof_kind": "configuration-only",
      "claim": "Codex owns the configured multi-agent thread and depth limits. Runtime application is not repository-verified.",
      "sources": [".codex/config.toml"],
      "proof": [".codex/config.toml"]
    },
    {
      "id": "claude-role-settings",
      "classification": "host-enforced",
      "proof_kind": "configuration-only",
      "claim": "Claude owns loading provider-owned project role and model settings after harness restart. Runtime application is not repository-verified.",
      "sources": [
        ".claude/agents/fast-worker.md",
        ".claude/agents/deep-reasoner.md"
      ],
      "proof": [
        ".claude/agents/fast-worker.md",
        ".claude/agents/deep-reasoner.md"
      ]
    },
    {
      "id": "enforcement-contract-integrity",
      "classification": "repository-validator-enforced",
      "proof_kind": "repository-validator",
      "claim": "Every listed rule has an allowed classification and every technical enforcement claim resolves to repository evidence.",
      "sources": ["ai_studio/core_harness/workflow/enforcement_contract.json"],
      "proof": [
        "ai_studio/core_harness/validation/enforcement_check.mjs",
        "ai_studio/core_harness/validation/tests/enforcement_check.test.mjs"
      ]
    },
    {
      "id": "core-doc-reference-integrity",
      "classification": "repository-validator-enforced",
      "proof_kind": "repository-validator",
      "claim": "Core Harness agent-facing document references resolve inside the repository.",
      "sources": ["ai_studio/core_harness/validation/README.md"],
      "proof": [
        "ai_studio/core_harness/validation/doc_reference_check.mjs",
        "ai_studio/core_harness/validation/tests/doc_reference_check.test.mjs"
      ]
    },
    {
      "id": "codex-role-model-smoke",
      "classification": "repository-validator-enforced",
      "proof_kind": "repository-validator",
      "claim": "A supplied native Codex subagent transcript matches the requested stock role and expected selected model without generic fallback.",
      "sources": ["ai_studio/core_harness/workflow/orchestration/README.md"],
      "proof": [
        "ai_studio/core_harness/validation/agent_role_smoke.mjs",
        "ai_studio/core_harness/validation/tests/agent_role_smoke.test.mjs"
      ]
    },
    {
      "id": "repository-agent-invariants",
      "classification": "process convention",
      "claim": "Repository role, game ownership, engine, UI, asset, provenance, and context-routing instructions are followed by agents and reviewed by the lead.",
      "sources": ["AGENTS.md", "CLAUDE.md"],
      "proof": []
    },
    {
      "id": "scoped-work-loop",
      "classification": "process convention",
      "claim": "Agents keep context scoped, make the smallest coherent change, run narrow proof, and record useful evidence.",
      "sources": ["ai_studio/core_harness/workflow/README.md"],
      "proof": []
    },
    {
      "id": "delegation-policy",
      "classification": "process convention",
      "claim": "The lead delegates non-trivial work to the closest provider-owned role with bounded packets and integrates the result.",
      "sources": [
        "AGENTS.md",
        "ai_studio/core_harness/workflow/orchestration/README.md"
      ],
      "proof": []
    },
    {
      "id": "task-log-and-quality-decisions",
      "classification": "process convention",
      "claim": "Task logs and quality outcomes are evidence-backed handoff assertions, not proof that a host or repository validator enforced the workflow.",
      "sources": [
        "ai_studio/core_harness/workflow/README.md",
        "ai_studio/quality/README.md"
      ],
      "proof": []
    }
  ]
}
