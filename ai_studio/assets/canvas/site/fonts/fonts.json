        { "weight": 600, "style": "normal", "file": "Inter/Inter-SemiBold.ttf", "origin": "https://raw.githubusercontent.com/google/fonts/main/ofl/inter/Inter[opsz,wght].ttf", "instance": "wght=600 opsz=14" },
