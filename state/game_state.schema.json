    {
      "path": "run.xp",
      "id": 18,
      "type": "int",
      "default": 0,
      "devapi": "read_write",
      "min": 0,
      "max": 2147483647
    },
    {
      "path": "run.xp_to_next",
      "id": 19,
      "type": "int",
      "default": 60,
      "devapi": "read_write",
      "min": 1,
      "max": 2147483647
    },
    {
      "path": "run.enemies_defeated",
      "id": 20,
      "type": "int",
      "default": 0,
      "devapi": "read_write",
      "min": 0,
      "max": 2147483647
    },
    {
      "path": "run.keep_reached",
      "id": 21,
      "type": "bool",
      "default": false,
      "devapi": "read_write"
    },
    {
      "path": "run.ftue_step",
      "id": 22,
      "type": "int",
      "default": 0,
      "devapi": "read_write",
      "min": 0,
      "max": 9
    }
  ]
}
