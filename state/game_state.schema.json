{
  "schema": "game_seed.state",
  "document": "game",
  "lifetime": "persistent_profile",
  "version": 2,
  "string_max": 64,
  "reserved": [
    {
      "id": 99,
      "path": "grabbed",
      "reason": "runtime input telemetry, not persistent state"
    }
  ],
  "collections": {
    "items_max": 32,
    "inventory_item_ids_max": 32
  },
  "enums": {
    "Shape": [
      "cube",
      "sphere",
      "cylinder",
      "capsule"
    ],
    "RenderMode": [
      "solid_wire",
      "solid",
      "wire"
    ]
  },
  "types": {
    "ItemInstance": {
      "kind": "object",
      "fields": [
        {
          "path": "def_id",
          "id": 1,
          "type": "string",
          "max_length": 63
        },
        {
          "path": "count",
          "id": 2,
          "type": "int",
          "default": 1,
          "min": 1,
          "max": 999999
        },
        {
          "path": "level",
          "id": 3,
          "type": "int",
          "default": 1,
          "min": 1,
          "max": 9999
        },
        {
          "path": "durability",
          "id": 4,
          "type": "float",
          "default": 1,
          "min": 0,
          "max": 1
        }
      ]
    }
  },
  "fields": [
    {
      "path": "shape_index",
      "id": 1,
      "type": "enum",
      "default": "cube",
      "enum": "Shape",
      "devapi": "read_write"
    },
    {
      "path": "render_mode_index",
      "id": 2,
      "type": "enum",
      "default": "solid_wire",
      "enum": "RenderMode",
      "devapi": "read_write"
    },
    {
      "path": "camera_distance",
      "id": 3,
      "type": "float",
      "default": 6,
      "devapi": "read_write",
      "min": 2.5,
      "max": 10
    },
    {
      "path": "test_ui_clicks",
      "id": 4,
      "type": "int",
      "default": 0,
      "devapi": "read_write",
      "min": 0,
      "max": 1000000
    },
    {
      "path": "test_label_text",
      "id": 5,
      "type": "string",
      "default": "Template ready",
      "max_length": 63,
      "devapi": "read_write"
    },
    {
      "path": "test_button_text",
      "id": 6,
      "type": "string",
      "default": "Cycle",
      "max_length": 63,
      "devapi": "read_write"
    },
    {
      "path": "settings.master_volume",
      "id": 7,
      "type": "float",
      "default": 0.75,
      "devapi": "read_write",
      "min": 0,
      "max": 1
    },
    {
      "path": "settings.sfx_volume",
      "id": 8,
      "type": "float",
      "default": 0.8,
      "devapi": "read_write",
      "min": 0,
      "max": 1
    },
    {
      "path": "tutorial.done",
      "id": 9,
      "type": "bool",
      "default": false,
      "devapi": "read_write"
    },
    {
      "path": "wallet.soft",
      "id": 10,
      "type": "int",
      "default": 0,
      "devapi": "read_write",
      "min": 0,
      "max": 2147483647
    },
    {
      "path": "wallet.hard",
      "id": 11,
      "type": "int",
      "default": 0,
      "devapi": "read_write",
      "min": 0,
      "max": 2147483647
    },
    {
      "path": "items",
      "id": 12,
      "type": "map<string,ItemInstance>",
      "max_count": 32,
      "devapi": "read_write"
    },
    {
      "path": "inventory.item_ids",
      "id": 13,
      "type": "list<string>",
      "max_count": 32,
      "devapi": "read_write"
    },
    {
      "path": "equipment.hand_item_id",
      "id": 14,
      "type": "string?",
      "default": null,
      "max_length": 63,
      "devapi": "read_write"
    },
    {
      "path": "run.hero_hp",
      "id": 15,
      "type": "int",
