{
  "schema": "game_seed.state",
  "document": "game",
  "lifetime": "persistent_profile",
  "version": 1,
  "string_max": 64,
  "collections": {
    "items_max": 32,
    "inventory_item_ids_max": 32
  },
  "enums": {
    "GameMode": [
      "live",
      "build"
    ],
    "SimAction": [
      "idle",
      "walking",
      "using",
      "social",
      "work",
      "sleep"
    ]
  },
  "types": {
    "ItemInstance": {
      "kind": "object",
      "fields": [
        {
          "path": "def_id",
          "id": 1,
          "type": "string",
          "max_length": 63
        },
        {
          "path": "count",
          "id": 2,
          "type": "int",
          "default": 1,
          "min": 1,
          "max": 999999
        },
        {
          "path": "level",
          "id": 3,
          "type": "int",
          "default": 1,
          "min": 1,
          "max": 9999
        },
        {
          "path": "durability",
          "id": 4,
          "type": "float",
          "default": 1,
          "min": 0,
          "max": 1
        }
      ]
    }
  },
  "fields": [
    {
      "path": "mode_index",
      "id": 1,
      "type": "enum",
      "default": "live",
      "enum": "GameMode",
      "devapi": "read_write"
    },
    {
      "path": "selected_sim",
      "id": 2,
      "type": "int",
      "default": 0,
      "devapi": "read_write",
      "min": 0,
      "max": 15
    },
    {
      "path": "sim_count",
      "id": 3,
      "type": "int",
      "default": 0,
      "devapi": "read_write",
      "min": 0,
      "max": 16
    },
    {
      "path": "clock.minutes",
      "id": 4,
      "type": "float",
      "default": 480,
      "devapi": "read_write",
      "min": 0,
      "max": 1440
    },
    {
      "path": "clock.day",
      "id": 5,
      "type": "int",
      "default": 1,
      "devapi": "read_write",
      "min": 1,
      "max": 9999
    },
    {
      "path": "wallet.simoleons",
      "id": 6,
      "type": "int",
      "default": 2000,
      "devapi": "read_write",
      "min": 0,
      "max": 2147483647
    },
    {
      "path": "stats.interactions",
      "id": 7,
      "type": "int",
      "default": 0,
      "devapi": "read_write",
      "min": 0,
      "max": 100000000
    },
    {
      "path": "camera.yaw",
      "id": 8,
      "type": "float",
      "default": 0.7,
      "devapi": "read_write",
      "min": -3.2,
      "max": 3.2
    },
    {
      "path": "camera.pitch",
      "id": 9,
      "type": "float",
      "default": 0.62,
      "devapi": "read_write",
      "min": 0.1,
      "max": 1.5
    },
    {
      "path": "camera.distance",
      "id": 10,
      "type": "float",
      "default": 20,
      "devapi": "read_write",
      "min": 6,
      "max": 48
    },
    {
      "path": "camera.target_x",
      "id": 11,
      "type": "float",
      "default": 0,
      "devapi": "read_write",
      "min": -200,
      "max": 200
    },
    {
      "path": "camera.target_z",
      "id": 12,
      "type": "float",
      "default": 0,
      "devapi": "read_write",
      "min": -200,
      "max": 200
    },
    {
      "path": "settings.master_volume",
      "id": 13,
      "type": "float",
      "default": 0.75,
      "devapi": "read_write",
      "min": 0,
      "max": 1
    },
    {
      "path": "settings.sfx_volume",
      "id": 14,
      "type": "float",
      "default": 0.8,
      "devapi": "read_write",
      "min": 0,
      "max": 1
    },
    {
      "path": "tutorial.done",
      "id": 15,
      "type": "bool",
      "default": false,
      "devapi": "read_write"
    },
    {
      "path": "items",
      "id": 16,
      "type": "map<string,ItemInstance>",
      "max_count": 32,
      "devapi": "read_write"
    },
    {
      "path": "inventory.item_ids",
      "id": 17,
      "type": "list<string>",
      "max_count": 32,
      "devapi": "read_write"
    },
    {
      "path": "equipment.hand_item_id",
      "id": 18,
      "type": "string?",
      "default": null,
      "max_length": 63,
      "devapi": "read_write"
    }
  ]
}
