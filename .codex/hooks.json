{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "tools/ai_profile/hook_record_fast codex",
            "commandWindows": "tools\\ai_profile\\hook_record_fast.exe codex"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "(?i)(bash|shell|exec)",
        "hooks": [
          {
            "type": "command",
            "command": "tools/ai_profile/hook_record_fast codex",
            "commandWindows": "tools\\ai_profile\\hook_record_fast.exe codex"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "(?i)(bash|shell|exec)",
        "hooks": [
          {
            "type": "command",
            "command": "tools/ai_profile/hook_record_fast codex",
            "commandWindows": "tools\\ai_profile\\hook_record_fast.exe codex"
          }
        ]
      }
    ]
  }
}
