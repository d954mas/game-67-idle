      "prerequisites": [
        {
          "quest_completed": "q001_gate_pass"
        },
        {
          "flag": "map_gate_unlocked"
        }
      ],
      "journal": {
        "summary": "Старая мельница не отвечает, а Последнему Посту нужен хлеб. Контракт выглядит простым, пока не появляется знак Черного Солнца.",
        "short_goal": "Добраться до Старой мельницы и вернуть зерно."
      },
      "steps": [
        {
          "id": "accept_bread_contract",
          "title": "Р’Р·СЏС‚СЊ РєРѕРЅС‚СЂР°РєС‚ Сѓ РЎС‚Р°СЂРѕСЃС‚С‹",
          "description": "РЎС‚Р°СЂРѕСЃС‚Р° РїСЂРѕСЃРёС‚ РїСЂРѕРІРµСЂРёС‚СЊ РЎС‚Р°СЂСѓСЋ РјРµР»СЊРЅРёС†Сѓ Рё РІРµСЂРЅСѓС‚СЊ Р·РµСЂРЅРѕ РґР»СЏ РџРѕСЃС‚Р°.",
          "location_id": "hub_last_post",
          "objective": {
            "type": "talk_to_npc",
            "target_id": "elder",
            "count": 1
          },
          "dialogue_id": "dlg_elder_bread_contract",
          "ui_hint": "РџРѕРіРѕРІРѕСЂРё СЃРѕ РЎС‚Р°СЂРѕСЃС‚РѕР№ РІ РџРѕСЃР»РµРґРЅРµРј РџРѕСЃС‚Рµ."
        },
        {
          "id": "visit_old_mill",
          "title": "Добраться до Старой мельницы",
          "description": "Найти Старую мельницу на карте и перейти в локацию.",
          "location_id": "old_mill",
          "objective": {
            "type": "visit_location",
            "location_id": "old_mill",
            "count": 1
          },
          "ui_hint": "Открой карту и выбери Старую мельницу."
        },
        {
          "id": "q002_clear_mill_yard",
          "title": "Выиграть бой",
          "description": "Шаг релизного квеста q002_bread_for_post: выиграть бой.",
          "location_id": "hub_last_post",
          "objective": {
            "type": "win_encounter",
            "count": 1,
            "encounter_id": "mill_scavenger"
          },
          "ui_hint": "Следуй отмеченной цели в журнале."
        },
        {
          "id": "q002_clear_mill_brute",
          "title": "Выиграть бой",
          "description": "Шаг релизного квеста q002_bread_for_post: выиграть бой.",
          "location_id": "hub_last_post",
          "objective": {
            "type": "win_encounter",
            "count": 1,
