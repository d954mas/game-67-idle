  "ui_contract": {
    "always_show": ["vitality", "strength", "protection", "intuition", "attack_power"],
    "details_show": ["weapon_damage", "attack_interval", "crit_chance", "block_chance"],
    "prefight_panel": [
      "enemy_portrait_and_name",
      "player_hp_strength_protection_intuition_damage",
      "enemy_hp_damage_protection_intuition",
      "threat_label",
      "one_reason_line",
      "expected_rewards",
      "fight_button",
      "back_button",
      "heal_button_when_relevant",
      "upgrade_button_when_relevant"
    ],
    "combat_view": [
      "two_hp_bars",
      "attack_pips_or_swing_timers",
      "floating_damage_numbers",
      "crit_marker_only_when_it_happens",
      "block_marker_only_when_it_happens",
      "last_3_combat_events",
      "result_panel_with_reward_and_next_quest_or_clue"
    ],
    "item_cards": [
      "show_direct_stat_deltas",
      "show_final_attack_power_preview_on_weapon_cards",
      "hide_expected_dps_outside_debug"
    ]
  },
  "balance_rules": [
    "mandatory early fights should be easy or fair with intended gear and at least 70 percent player hp",
    "optional danger can be risky; story gates should not be deadly",
    "ten strength should increase final attack power by one",
    "one weapon upgrade should reduce hits-to-kill against at least one current enemy",
    "one armour upgrade should increase hits-survived or add visible blocked hits",
    "crit should never be required for mandatory victory",
    "if the player loses, the next best action must be obvious from the result screen"
  ],
  "deferred_stats": [
