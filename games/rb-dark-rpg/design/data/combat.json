{
  "schema": "ai_studio.game_design.combat.v4",
  "game_id": "rb-dark-rpg",
  "status": "draft",
  "combat_mode": "pure_autobattle",
  "design_goal": "Legend-style visible stats without a hidden armour mitigation curve: strength for physical damage, vitality for HP, protection for block, intuition for crit.",
  "design_doc": "../combat_mechanics.md",
  "reference_model": {
    "primary_reference": "Legend: Legacy of the Dragons official Character Attributes",
    "source_url": "https://warofdragons.com/info/library/index.php?obj=cat&id=429",
    "fixed_decisions": [
      "damage is derived from weapon damage plus strength scaling",
      "vitality is max HP",
      "protection is block chance, not armour absorption",
      "intuition is crit chance",
      "critical hits cannot be blocked",
      "agility/dodge and active super-blows are deferred"
    ]
  },
  "player_decisions": [
    "accept_or_postpone_quest",
    "equip_weapon_and_armour",
    "heal_or_risk_fighting_wounded",
    "read_prefight_threat",
    "start_fight_or_upgrade_first"
  ],
  "visible_stats": [
    {
      "id": "vitality",
      "display_name": "Живучесть",
      "tier": "primary",
      "unit": "points",
      "effect": "Max HP. One vitality equals one HP.",
      "ui_rule": "always_show"
    },
    {
      "id": "strength",
      "display_name": "Сила",
      "tier": "primary",
      "unit": "points",
      "effect": "Physical damage growth. Ten strength adds one average physical damage.",
      "ui_rule": "always_show"
    },
    {
      "id": "protection",
      "display_name": "Защита",
      "tier": "primary",
      "unit": "points",
      "effect": "Block chance against normal physical hits.",
      "ui_rule": "always_show"
    },
    {
      "id": "intuition",
      "display_name": "Интуиция",
      "tier": "primary",
      "unit": "points",
      "effect": "Physical critical hit chance. Intuition crits cannot be blocked.",
      "ui_rule": "always_show"
    },
    {
      "id": "weapon_damage",
      "display_name": "Урон оружия",
      "tier": "item_primary",
      "unit": "points",
      "effect": "Base weapon contribution to physical hits.",
      "ui_rule": "item_cards_and_details"
    },
    {
      "id": "attack_interval",
      "display_name": "Скорость",
      "tier": "secondary",
      "unit": "seconds_between_attacks",
      "effect": "Lower value attacks more often.",
      "ui_rule": "details_and_enemy_cards"
    }
  ],
  "derived_stats": [
    {
      "id": "max_hp",
      "formula": "vitality",
      "player_visible": true
    },
    {
      "id": "attack_power",
      "formula": "weapon_damage + floor(strength / 10) + bonus_attack_power",
      "player_visible": true
    },
    {
      "id": "crit_chance",
      "formula": "min(0.30, intuition / 100)",
      "player_visible": "details"
    },
    {
      "id": "block_chance",
      "formula": "min(0.35, protection / 100)",
      "player_visible": "details"
    },
    {
      "id": "blocked_hit",
      "formula": "max(1, ceil(attack_power * 0.5))",
      "player_visible": false
    },
    {
      "id": "crit_hit",
      "formula": "attack_power * 2",
      "player_visible": false
    }
  ],
  "rules": {
    "attack_power": "weapon_damage + floor(strength / 10) + bonus_attack_power",
    "crit": "roll crit first; if random < crit_chance, deal attack_power * 2 and skip defender block",
    "block": "if no crit and random < defender.block_chance, damage = max(1, ceil(attack_power * 0.5))",
    "normal_hit": "if no crit and no block, damage = attack_power",
    "damage_variance": "none_in_v1",
    "attack_timing": "each unit attacks automatically when its attack timer reaches attack_interval",
    "timer_start": "opening_offsets: player starts near 36% of attack_interval, enemy near 62% of attack_interval",
    "ready_order": "if both attacks are ready on the same timestamp, resolve player attack first, then delay the next event by a short combat beat",
    "minimum_event_spacing_seconds": 0.32,
    "simultaneous_ko": "player_wins_with_1_hp",
    "win": "enemy current_hp reaches 0",
    "loss": "player current_hp reaches 0",
    "retreat": "available_before_combat_only"
  },
  "prefight_threat": {
    "shown_to_player": true,
    "show_percentages": false,
    "labels": [
      {
        "id": "easy",
        "display_name": "Легко",
        "internal_rule": "predicted_win_chance >= 0.80"
      },
      {
        "id": "fair",
        "display_name": "Ровно",
        "internal_rule": "predicted_win_chance >= 0.60 and < 0.80"
      },
      {
        "id": "risky",
        "display_name": "Риск",
        "internal_rule": "predicted_win_chance >= 0.40 and < 0.60"
      },
      {
        "id": "deadly",
        "display_name": "Смертельно",
        "internal_rule": "predicted_win_chance < 0.40"
      }
    ],
    "reason_lines": [
      "У тебя достаточно живучести для этой встречи.",
      "Его защита часто режет обычные удары.",
      "Тебе не хватает силы или оружия.",
      "Враг бьет чаще тебя.",
      "У врага высокий шанс крита."
    ]
  },
