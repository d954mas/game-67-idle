      "player_hp": 1,
      "gold_loss": 0,
      "item_loss": "none",
      "encounter_progress": "reset_current_encounter",
      "explanation": "show_main_mismatch_low_hp_low_strength_low_weapon_damage_low_protection_enemy_speed_or_enemy_crit"
    },
