  "status": "draft",
  "dialogues": [
    {
      "id": "dlg_gate_guard_intro",
      "title": "Страж: допуск за ворота",
      "participants": [
        "gate_guard",
        "player_seeker"
      ],
      "entry_node_id": "start",
      "quest_preview": {
        "goal": "Надень меч, броню и поножи, убери падальщика у ворот и вернись к стражу.",
        "immediate_rewards": [
          {
            "type": "item",
            "item_id": "old_sword",
            "count": 1
          },
          {
            "type": "item",
            "item_id": "padded_jacket",
            "count": 1
          },
          {
            "type": "item",
            "item_id": "leather_greaves",
            "count": 1
          }
        ],
        "completion_rewards": [
          {
            "type": "item",
            "item_id": "seeker_token",
            "count": 1
          },
          {
            "type": "grant_xp",
            "amount": 12
          }
        ]
      },
      "nodes": [
        {
          "id": "start",
          "speaker_id": "gate_guard",
          "text": "За ворота без жетона и железа не выпускаю. На трактах падальщики и люди с черным знаком. Хочешь выйти - пройдешь проверку.",
          "choices": [
            {
              "id": "ask_what_happened",
              "text": "Что случилось за воротами?",
              "next_node_id": "outside_lore"
            },
            {
              "id": "ask_what_needed",
              "text": "Что за проверка?",
              "next_node_id": "explain_check"
            },
            {
              "id": "accept",
              "text": "Беру снаряжение",
              "reward_id": "dlg_gate_guard_intro.accept.immediate",
              "effects": [
                {
                  "type": "grant_item",
                  "item_id": "old_sword",
                  "count": 1
                },
                {
                  "type": "grant_item",
                  "item_id": "padded_jacket",
                  "count": 1
                },
                {
                  "type": "grant_item",
                  "item_id": "leather_greaves",
                  "count": 1
                },
                {
                  "type": "set_flag",
                  "flag_id": "gate_guard_intro_seen"
                },
                {
                  "type": "set_flag",
                  "flag_id": "starter_gear_received"
                },
                {
                  "type": "advance_quest",
                  "quest_id": "q001_gate_pass",
                  "step_id": "talk_gate_guard"
                }
              ]
            }
          ]
        },
        {
          "id": "outside_lore",
          "speaker_id": "gate_guard",
          "text": "Последний Пост держится на тех, кто возвращается с новостями. Совет платит за сведения, но сначала ты должен доказать, что не станешь еще одним телом у дороги.",
          "choices": [
            {
              "id": "ask_what_needed",
              "text": "Что за проверка?",
              "next_node_id": "explain_check"
            },
            {
              "id": "accept",
              "text": "Беру снаряжение",
              "reward_id": "dlg_gate_guard_intro.accept.immediate",
              "effects": [
                {
                  "type": "grant_item",
                  "item_id": "old_sword",
                  "count": 1
                },
                {
                  "type": "grant_item",
                  "item_id": "padded_jacket",
                  "count": 1
                },
                {
                  "type": "grant_item",
                  "item_id": "leather_greaves",
                  "count": 1
                },
                {
                  "type": "set_flag",
                  "flag_id": "gate_guard_intro_seen"
                },
                {
                  "type": "set_flag",
                  "flag_id": "starter_gear_received"
                },
                {
                  "type": "advance_quest",
                  "quest_id": "q001_gate_pass",
                  "step_id": "talk_gate_guard"
                }
              ]
            }
          ]
        },
        {
          "id": "explain_check",
          "speaker_id": "gate_guard",
          "text": "Я выдам старый меч, стеганую куртку и поножи прямо сейчас. Надень комплект, убери падальщика у ворот, потом вернешься ко мне за жетоном искателя.",
          "choices": [
            {
              "id": "ask_what_happened",
              "text": "Почему все так плохо?",
              "next_node_id": "outside_lore"
            },
            {
              "id": "accept",
              "text": "Беру снаряжение",
              "reward_id": "dlg_gate_guard_intro.accept.immediate",
              "effects": [
                {
                  "type": "grant_item",
                  "item_id": "old_sword",
                  "count": 1
                },
                {
                  "type": "grant_item",
                  "item_id": "padded_jacket",
                  "count": 1
                },
                {
                  "type": "grant_item",
                  "item_id": "leather_greaves",
                  "count": 1
                },
                {
                  "type": "set_flag",
                  "flag_id": "gate_guard_intro_seen"
                },
                {
                  "type": "set_flag",
                  "flag_id": "starter_gear_received"
                },
                {
                  "type": "advance_quest",
                  "quest_id": "q001_gate_pass",
                  "step_id": "talk_gate_guard"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "dlg_gate_guard_turn_in",
      "title": "Страж: жетон искателя",
      "participants": [
        "gate_guard",
        "player_seeker"
      ],
      "entry_node_id": "start",
      "nodes": [
        {
          "id": "start",
          "speaker_id": "gate_guard",
          "text": "Вернулся. Значит, не зря выдавали железо. Держи жетон искателя. Теперь можешь брать настоящие контракты.",
          "choices": [
            {
              "id": "take_token",
              "text": "Взять жетон.",
              "reward_id": "dlg_gate_guard_turn_in.take_token.completion",
              "effects": [
                {
                  "type": "grant_item",
                  "item_id": "seeker_token",
                  "count": 1
                },
                {
                  "type": "grant_xp",
                  "amount": 12
                },
                {
                  "type": "set_flag",
                  "flag_id": "seeker_token_owned"
                },
                {
                  "type": "set_flag",
                  "flag_id": "map_gate_unlocked"
                },
                {
                  "type": "set_flag",
                  "flag_id": "old_mill_unlocked"
                },
                {
                  "type": "advance_quest",
                  "quest_id": "q001_gate_pass",
                  "step_id": "report_to_gate_guard"
                },
                {
                  "type": "complete_quest",
                  "quest_id": "q001_gate_pass"
                },
                {
                  "type": "advance_quest",
                  "quest_id": "q002_bread_for_post",
                  "step_id": "accept_bread_contract"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "dlg_elder_bread_contract",
      "title": "Староста: хлеб для Поста",
      "participants": [
        "elder",
        "player_seeker"
      ],
      "entry_node_id": "start",
      "nodes": [
        {
          "id": "start",
          "speaker_id": "elder",
          "text": "Жетон есть, значит можно дать настоящее поручение. Старая мельница молчит, а Посту нужен хлеб. Доберись туда и проверь двор.",
          "choices": [
            {
              "id": "accept_bread_contract",
              "text": "Взять контракт",
              "effects": [
                {
                  "type": "advance_quest",
                  "quest_id": "q002_bread_for_post",
                  "step_id": "accept_bread_contract"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "dlg_elder_bread_in_progress",
      "title": "Староста: мельница ждет",
      "participants": [
        "elder",
        "player_seeker"
      ],
      "entry_node_id": "start",
      "nodes": [
        {
          "id": "start",
          "speaker_id": "elder",
          "text": "Не тяни. Открой карту, дойди до Старой мельницы и осмотри знак во дворе.",
          "choices": []
        }
      ]
    },
    {
      "id": "dlg_elder_bread_turn_in",
      "title": "Староста: знак на мельнице",
      "participants": [
        "elder",
        "player_seeker"
      ],
      "entry_node_id": "start",
      "nodes": [
        {
          "id": "start",
          "speaker_id": "elder",
          "text": "Зерно можно забрать позже. Сейчас важнее знак Черного Солнца. Совет должен узнать, что мельницу пометили.",
          "choices": [
            {
              "id": "report_bread_contract",
              "text": "Сдать находку",
              "reward_id": "dlg_elder_bread_turn_in.report.completion",
              "effects": [
                {
                  "type": "grant_xp",
                  "amount": 10
                },
                {
                  "type": "grant_gold",
                  "amount": 6
                },
                {
                  "type": "advance_quest",
                  "quest_id": "q002_bread_for_post",
                  "step_id": "report_to_elder"
                },
                {
                  "type": "complete_quest",
                  "quest_id": "q002_bread_for_post"
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "id": "dlg_elder_bread_completed",
      "title": "Староста: новые вести",
      "participants": [
        "elder",
        "player_seeker"
      ],
      "entry_node_id": "start",
      "nodes": [
        {
          "id": "start",
          "speaker_id": "elder",
          "text": "Ты сделал, что нужно. Дальше Совет разберется со знаком.",
          "choices": []
        }
      ]
    },
    {
      "id": "dlg_blacksmith_starter_gear",
      "title": "Кузнец: первое снаряжение",
      "participants": [
        "blacksmith",
        "player_seeker"
      ],
      "entry_node_id": "start",
      "nodes": [
        {
          "id": "start",
          "speaker_id": "blacksmith",
          "text": "Страж уже выдал тебе старый комплект. Не спорь с железом: надень меч, куртку и поножи, а потом возвращайся к воротам.",
          "choices": [
            {
              "id": "close",
              "text": "Понял."
            }
          ]
        }
      ]
    },
    {
      "id": "dlg_council_scribe_placeholder",
      "title": "Писарь: заглушка",
      "participants": [
        "council_scribe",
        "player_seeker"
      ],
      "entry_node_id": "start",
      "nodes": [
        {
          "id": "start",
          "speaker_id": "council_scribe",
          "text": "Отчеты принимаются после контрактов. Печати Совета без дела не ставятся.",
          "choices": [
            {
              "id": "close",
              "text": "Понятно."
            }
          ]
        }
      ]
    },
    {
      "id": "dlg_q003_sign_in_cellar_start",
      "title": "Знак в подвале: старт",
      "participants": [
        "council_scribe",
        "player_seeker"
      ],
      "entry_node_id": "start",
      "nodes": [
        {
          "id": "start",
          "speaker_id": "council_scribe",
          "text": "Коротко: дело стало опаснее. Возьми цель, проверь след и возвращайся с доказательством.",
          "choices": [
