{
  "schema": "runway_awakening.state",
  "schema_version": 2,
  "fragment": "game",
  "version": 2,
  "string_max": 32,
  "migrations": [
    { "to_version": 2, "fn": "game_migrate_1_to_2" }
  ],
  "types": {
    "SavedLook": {
      "kind": "object",
      "fields": {
        "hair_id": { "type": "string", "default": "none", "max_length": 31 },
        "main_id": { "type": "string", "default": "none", "max_length": 31 },
        "bottom_id": { "type": "string", "default": "none", "max_length": 31 },
        "shoes_id": { "type": "string", "default": "none", "max_length": 31 },
        "accent_id": { "type": "string", "default": "none", "max_length": 31 }
      }
    }
  },
  "reserved": [
    "grabbed",
    "settings.master_volume",
    "settings.sfx_volume",
    "shape_index",
    "render_mode_index",
    "camera_distance",
    "test_ui_clicks",
    "test_label_text",
    "test_button_text",
    "tutorial.done"
  ],
  "fields": {
    "outfit_hair_id": { "type": "string", "default": "none", "max_length": 31 },
    "outfit_main_id": { "type": "string", "default": "none", "max_length": 31 },
    "outfit_bottom_id": { "type": "string", "default": "none", "max_length": 31 },
    "outfit_shoes_id": { "type": "string", "default": "none", "max_length": 31 },
    "outfit_accent_id": { "type": "string", "default": "none", "max_length": 31 },
    "recipe_mask": { "type": "int", "default": 0, "min": 0, "max": 63 },
    "lookbook_mask": { "type": "int", "default": 0, "min": 0, "max": 262143 },
    "essence_mask": { "type": "int", "default": 0, "min": 0, "max": 7 },
    "rounds_completed": { "type": "int", "default": 0, "min": 0, "max": 1000000 },
    "first_equip_done": { "type": "bool", "default": false },
    "saved_looks": { "type": "map<string,SavedLook>", "max_count": 18 }
  }
}
