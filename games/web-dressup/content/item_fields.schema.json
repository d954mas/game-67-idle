{
  "schema": "game_seed.items_fields",
  "schema_version": 2,
  "namespace_pattern": "^[a-z][a-z0-9_]*\\.[a-z][a-z0-9_]*$",
  "core": {
    "id":            { "type": "string", "required": true },
    "created":       { "type": "string", "required": true },
    "display_name":  { "type": "string", "required": true },
    "icon_asset_id": { "type": "string", "required": true },
    "kind":          { "type": "string", "required": true },
    "tags":          { "type": "list<string>", "required": false },
    "base_value":    { "type": "i64", "required": true },
    "stack": { "type": "i64", "required": true, "note": "0 = unlimited stack, 1 = unique/instance (non-stackable), N>1 = stack cap" }
  },
  "blocks": {
    "equip": {
      "fields": {
        "slot": { "type": "string", "required": true }
      }
    },
    "use": {
      "fields": {
        "effect_id": { "type": "string", "required": true },
        "params":    { "type": "object", "required": false }
      }
    },
    "currency": {
      "fields": {
        "hud_hint": { "type": "string", "required": true },
        "cap":      { "type": "i64", "required": false }
      }
    }
  },
  "item_kinds": {
    "fields": {
      "id":    { "type": "string", "required": true },
      "label": { "type": "string", "required": true }
    }
  },
  "containers": {
    "fields": {
      "id":             { "type": "string", "required": true },
      "capacity":       { "type": "i64", "required": true },
      "accept_policy":  { "type": "enum", "enum": ["any", "currency_only", "slot_filter", "capacity_1"], "required": true },
      "hidden":         { "type": "bool", "required": true }
    }
  },
  "reserved_namespaces": ["ui"]
}
