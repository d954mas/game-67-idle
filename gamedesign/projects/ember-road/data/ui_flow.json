{
  "schema": "game.ui_flow",
  "project": "ember-road",
  "first_screen": "town_square",
  "screens": [
    {
      "id": "town_square",
      "purpose": "Orient the player, show hero status, offer the first quest, and make the fantasy UI visible.",
      "required_elements": [
        "fantasy town background",
        "hero portrait/status panel",
        "top bar with gold/xp/level",
        "quest NPC panel",
        "mini map strip",
        "primary action: accept quest or claim reward",
        "locked destination hint"
      ],
      "transitions": [
        "map_view",
        "inventory_panel",
        "quest_panel"
      ]
    },
    {
      "id": "map_view",
      "purpose": "Let the player travel between the town and one unlocked encounter node.",
      "required_elements": [
        "Old Gate town node",
        "North Road unlocked node",
        "Old Mine locked node",
        "quest marker",
        "travel button or direct node click"
      ],
      "transitions": [
        "town_square",
        "battle_overlay"
      ]
    },
    {
      "id": "battle_overlay",
      "purpose": "Show automated combat as an animated RPG result, not a hidden calculation.",
      "required_elements": [
        "hero combat portrait",
        "enemy portrait or sprite",
        "HP bars",
        "round log",
        "hit flashes or motion",
        "result banner"
      ],
      "transitions": [
        "loot_result"
      ]
    },
    {
      "id": "loot_result",
      "purpose": "Show XP, gold, item, and next choice after battle.",
      "required_elements": [
        "XP fill animation",
        "gold gain",
        "item card",
        "Equip button",
        "Keep button",
        "Return to town button"
      ],
      "transitions": [
        "inventory_panel",
        "town_square",
        "map_view"
      ]
    },
    {
      "id": "inventory_panel",
      "purpose": "Compare the first item and prove item progression.",
      "required_elements": [
        "equipment slot",
        "item card",
        "before/after attack value",
        "equip/keep controls"
      ],
      "transitions": [
        "town_square",
        "loot_result"
      ]
    }
  ],
  "live_state_coverage": [
    "first_screen",
    "hud_visible",
    "primary_action_ready",
    "primary_action_feedback",
    "reward_active",
    "progression_panel_open",
    "modal_or_choice_open",
    "locked_or_disabled_state",
    "resume_or_reentry_state",
    "transient_stress_state"
  ]
}
