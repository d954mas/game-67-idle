  "responsive_runtime_rules": {
    "landscape": [
      "top stage must read as one actor-target-reward cluster, not a small icon on a wide empty panel",
      "lower board may be dense, but active Mining and next goal must be visually heavier than future chips"
    ],
    "portrait": [
      "top stage must be the first read and use fewer simultaneous HUD values",
      "primary activity row should be full width, with secondary/future activities below",
      "do not squeeze desktop stat strings into compact chips"
    ]
