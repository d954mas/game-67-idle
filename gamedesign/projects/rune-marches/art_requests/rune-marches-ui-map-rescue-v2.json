{
  "schema": "game.art_job",
  "version": 1,
  "id": "rune-marches-ui-map-rescue-v2",
  "status": "draft",
  "asset_family": "runtime-ui-map-kit",
  "audience": "casual PC/web/mobile players; first-session fantasy RPG clarity",
  "runtime_harness": "native PC",
  "visual_targets": [
    "gamedesign/projects/rune-marches/art/art_direction.md",
    "gamedesign/projects/rune-marches/art/ui_design_bible_v2.md",
    "gamedesign/sources/generated_game_ui_asset_pipeline_research_2026-06-14.md",
    "gamedesign/projects/rune-marches/reviews/visual_product_profile_review_2026-06-13.md"
  ],
  "problem_statement": "Current native screenshots look like a debug UI over cropped fake-shot art. Rescue pass must make the first screen readable as a polished casual fantasy RPG: clear place, clear goal, clear first action, clear reward.",
  "candidate_policy": {
    "target_count": 6,
    "keep_raw_candidates": true,
    "reject_to_tmp": true,
    "accept_one_or_two_for_runtime": true
  },
  "reusable_kinds": [
    "sprite",
    "slice9",
    "icon",
    "tile",
    "border",
    "effect"
  ],
  "required_asset_groups": [
    {
      "id": "first_screen_map",
      "kind": "background",
      "need": "Clean painted map for Miregate, Wispfen Road, Old Bell Tower, Reedmere, Greenfen, Briar Gate, Moonwell, Ashen Cairn, and Starfall Grotto with label-safe empty areas."
    },
    {
      "id": "landmark_icons",
      "kind": "sprite",
      "need": "Separate readable icons for each location, locked/unlocked variants where needed, transparent or chroma-key source.",
      "anchor_policy": "bottom-center pivot for map pins and center pivot for free icons"
    },
    {
      "id": "exploration_ui",
      "kind": "slice9",
      "need": "One primary action button, small secondary buttons, journal panel, reward chip, status strips, and selected/disabled/affordable states.",
      "states": ["idle", "pressed", "disabled", "selected"],
      "content_policy": "runtime labels/icons stay inside recorded content safe area",
      "stretch_zone_policy": "center and long edges must be plain or repeatable texture; unique medallions, gems, badges, caps, and center ornaments cannot live in stretch zones",
      "decor_overlay_policy": "non-stretch ornaments must be corner-only or exported as separate ui decor overlay sheet sprites with runtime anchors",
      "target_preview_sizes": [[128, 48], [180, 56], [240, 64], [360, 240], [520, 320]]
    },
    {
      "id": "combat_ui",
      "kind": "slice9",
      "need": "Combat-only action buttons and enemy panel; do not keep combat grid visible during exploration.",
      "states": ["idle", "pressed", "disabled"],
      "content_policy": "runtime combat labels/icons stay inside recorded content safe area",
      "stretch_zone_policy": "combat panels and buttons use the same plain/repeatable stretch zones; encounter-specific ornamentation is composed as overlays",
      "decor_overlay_policy": "enemy badges, danger caps, locks, and combat flourishes must be separate anchored sprites, not baked into resizable bases",
      "target_preview_sizes": [[128, 48], [180, 56], [240, 64], [300, 380]]
    },
    {
      "id": "resource_icons",
      "kind": "icon",
      "need": "HP, mana, silver, XP, level, road safety, lore, blessing icons readable at mobile size.",
      "size_class": "96px source; preview at 32px and 48px gameplay sizes"
    },
    {
      "id": "ui_decor_overlays",
      "kind": "sprite",
      "need": "Separate non-stretch corner caps, gems, badges, medallions, lock plates, ribbon banners, dividers, and small fantasy flourishes with transparent/chroma padding.",
      "anchor_policy": "record center or corner anchor before runtime composition; never bake these overlays into slice9 stretch zones"
    }
  ],
  "generation_contract": {
    "source_families": [
      "blank UI kit sheet",
      "isolated icon sheet",
      "ui decor overlay sheet",
      "world/map/background layer sheet",
      "sprite or FX sheet"
    ],
    "final_asset_policy": {
      "procedural_art_allowed": "debug_only",
      "runtime_final_must_use_generated_or_artist_source": true,
      "layered_source_required_for_ui": true,
      "notes": "Current procedural slice9 bases are a temporary geometry/proof scaffold after the lead rejected sliced generated panels. Final UI art must replace those bases with generated or artist-authored layered source families."
    },
    "source_family_roles": {
      "blank UI kit sheet": "stretchable bases: panels, button states, bars, frames, and chips without unique center decoration in slice9 stretch zones",
      "isolated icon sheet": "semantic HP/mana/currency/progression icons with gutters and transparent/chroma source",
      "ui decor overlay sheet": "non-stretch gems, badges, medallions, corner caps, and center ornaments with runtime anchors",
      "world/map/background layer sheet": "painted world/map background and landmark-safe areas",
      "sprite or FX sheet": "isolated effects and gameplay sprites with pivots"
    },
    "prompt_constraints": [
      "no readable text",
      "no fake letters",
      "no fused icons inside button backgrounds",
      "clear gutters between assets",
      "consistent perspective and lighting",
      "transparent or flat chroma-key background for isolated assets",
      "no unique decoration inside slice9 stretch zones"
    ],
    "metadata_to_record": [
      "provider or generator",
      "model/workflow",
      "workflow file or workflow json",
      "seed",
      "prompt",
      "negative prompt",
      "source family role",
      "accepted source image path",
      "rejected candidate notes"
    ],
    "accepted_source": "gamedesign/projects/rune-marches/art/source_sheets/rune-marches-ui-kit-source-v2.png",
    "notes": "This source sheet is a pipeline test and reusable UI direction pass. Icon extraction now uses component isolation, alpha trim, padding, and edge-fringe cleanup. Slice9 preview still shows ornament stretching risk; release art should regenerate cleaner long edges and wider icon gutters."
  },
  "must_not_bake": [
    "button labels",
    "resource counters",
    "timer values",
    "tutorial text",
    "debug text",
    "game state values",
    "quest state",
    "map labels"
  ],
