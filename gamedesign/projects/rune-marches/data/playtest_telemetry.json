{
  "schema": "rune_marches.playtest_telemetry",
  "version": 1,
  "source_packet": "gamedesign/projects/rune-marches/playtest/first_session_poki_packet.md",
  "status": "native_runtime_hooks_ready",
  "poki_sdk_integration": "paused_until_web_lane_reactivated",
  "session_events": [
    {
      "id": "rune_session_start",
      "category": "session",
      "what": "start",
      "action": "fresh_state",
      "native_trigger": "game.reset_playtest or game.rune.telemetry.reset",
      "native_evidence": "rune.main_quest_step == 0",
      "future_web_mapping": "PokiSDK.gameLoadingFinished(); PokiSDK.gameplayStart()"
    },
    {
      "id": "rune_ftue_first_action",
      "category": "ftue",
      "what": "first_action",
      "action": "scout_road",
      "native_trigger": "game.rune.scout",
      "native_evidence": "rune.main_quest_step >= 1",
      "future_web_mapping": "PokiSDK.measure('ftue','first_action','scout_road')"
    },
    {
      "id": "rune_combat_first_action",
      "category": "combat",
      "what": "first_action",
      "action": "spark_or_strike",
      "native_trigger": "game.rune.spark or game.rune.strike",
      "native_evidence": "rune.encounter == mire_wisp and rune.enemy_hp < 10",
      "future_web_mapping": "PokiSDK.measure('combat','first_action','spark_or_strike')"
    },
    {
      "id": "rune_ftue_first_reward",
      "category": "ftue",
      "what": "first_reward",
      "action": "mire_wisp_win",
      "native_trigger": "second combat action after first scout",
      "native_evidence": "rune.silver >= 6 and rune.xp >= 4 and rune.sparks >= 1",
      "future_web_mapping": "PokiSDK.measure('ftue','first_reward','mire_wisp_win')"
    },
    {
      "id": "rune_upgrade_spark_ward_1",
      "category": "progression",
      "what": "upgrade",
      "action": "spark_ward_1",
      "native_trigger": "game.rune.upgrade.spark_ward",
      "native_evidence": "rune.spell_level == 1 and rune.tower_unlocked == true",
      "future_web_mapping": "PokiSDK.happyTime(0.5); PokiSDK.measure('progression','upgrade','spark_ward_1')"
    },
    {
      "id": "rune_choice_bell_rope",
      "category": "quest",
      "what": "choice",
      "action": "bell_rope_kindness_or_silver",
      "native_trigger": "game.rune.quest.bell_rope.kindness or game.rune.quest.bell_rope.silver",
      "native_evidence": "rune.side_quest_step == 3",
      "future_web_mapping": "PokiSDK.measure('quest','choice','bell_rope')"
    },
    {
      "id": "rune_route_reedmere_open",
      "category": "world",
      "what": "route_open",
      "action": "reedmere_crossing",
      "native_trigger": "game.rune.inspect_tower",
      "native_evidence": "rune.east_road_unlocked == true",
      "future_web_mapping": "PokiSDK.measure('world','route_open','reedmere_crossing')"
    },
    {
      "id": "rune_route_greenfen_open",
      "category": "world",
      "what": "route_open",
      "action": "greenfen_causeway",
      "native_trigger": "game.rune.open_causeway",
      "native_evidence": "rune.causeway_unlocked == true",
      "future_web_mapping": "PokiSDK.measure('world','route_open','greenfen_causeway')"
    },
    {
      "id": "rune_level_warden_rank_2",
      "category": "progression",
      "what": "level_up",
      "action": "warden_rank_2",
      "native_trigger": "fen_shade win after total XP reaches 20",
      "native_evidence": "rune.player_level == 2 and rune_summary.hp_max == 24",
      "future_web_mapping": "PokiSDK.happyTime(0.7); PokiSDK.measure('progression','level_up','warden_rank_2')"
    },
    {
      "id": "rune_upgrade_spark_ward_2",
      "category": "progression",
      "what": "upgrade",
      "action": "spark_ward_2",
      "native_trigger": "game.rune.upgrade.spark_ward_2",
      "native_evidence": "rune.spell_level == 2 and rune_summary.spark_damage == 9",
      "future_web_mapping": "PokiSDK.happyTime(0.7); PokiSDK.measure('progression','upgrade','spark_ward_2')"
    },
    {
      "id": "rune_route_post_greenfen_choice",
      "category": "world",
      "what": "route_choice",
      "action": "briar_gate_or_moonwell",
      "native_trigger": "game.rune.choose_briar_gate or game.rune.choose_moonwell",
      "native_evidence": "rune.route_choice != none and rune.main_quest_step == 14",
      "future_web_mapping": "PokiSDK.measure('world','route_choice','post_greenfen')"
    },
    {
      "id": "rune_route_briar_clear",
      "category": "world",
      "what": "route_clear",
      "action": "briar_gate_first_threat",
      "native_trigger": "game.rune.scout_briar_gate followed by combat win",
      "native_evidence": "rune.briar_gate_safety >= 1 and rune.main_quest_step == 16",
      "future_web_mapping": "PokiSDK.measure('world','route_clear','briar_gate_first_threat')"
    },
    {
      "id": "rune_route_moonwell_clear",
      "category": "world",
      "what": "route_clear",
      "action": "moonwell_first_trial",
      "native_trigger": "game.rune.scout_moonwell followed by combat win",
      "native_evidence": "rune.moonwell_safety >= 1 and rune.moonwell_blessing >= 2",
      "future_web_mapping": "PokiSDK.measure('world','route_clear','moonwell_first_trial')"
    },
    {
      "id": "rune_route_ashen_cairn_open",
      "category": "world",
      "what": "route_open",
      "action": "ashen_cairn_discovery",
      "native_trigger": "game.rune.discover_ashen_cairn",
      "native_evidence": "rune.ashen_cairn_unlocked == true and rune.main_quest_step == 18",
      "future_web_mapping": "PokiSDK.measure('world','route_open','ashen_cairn')"
    },
    {
      "id": "rune_route_starfall_grotto_open",
      "category": "world",
      "what": "route_open",
      "action": "starfall_grotto_discovery",
      "native_trigger": "game.rune.discover_starfall_grotto",
      "native_evidence": "rune.starfall_grotto_unlocked == true and rune.main_quest_step == 18",
      "future_web_mapping": "PokiSDK.measure('world','route_open','starfall_grotto')"
    },
    {
      "id": "rune_stall_30s",
      "category": "ftue",
      "what": "stall",
      "action": "no_input_30s",
      "native_trigger": "future runtime timer; not counted by current native telemetry endpoint",
      "native_evidence": "no test_ui_clicks delta for 30 seconds",
      "future_web_mapping": "PokiSDK.measure('ftue','stall','no_input_30s')"
    },
    {
      "id": "rune_session_stop",
      "category": "session",
      "what": "stop",
      "action": "focus_lost_or_exit",
      "native_trigger": "future runtime lifecycle hook; not counted by current native telemetry endpoint",
      "native_evidence": "not implemented in native yet",
      "future_web_mapping": "PokiSDK.gameplayStop()"
    }
  ]
}
