{
  "schema": "rune_marches.ui_flow",
  "version": 1,
  "viewports": {
    "native_desktop": {
      "width": 960,
      "height": 540,
      "layout": "landscape"
    },
    "mobile_portrait_min": {
      "width": 360,
      "height": 640,
      "layout": "portrait"
    }
  },
  "screens": {
    "main": {
      "first_visible": true,
      "regions": [
        {
          "id": "top_status",
          "role": "status_bar",
          "contents": ["hp", "mana", "silver", "xp", "ward_rank"]
        },
        {
          "id": "world_map",
          "role": "map",
          "contents": ["miregate", "wispfen_road", "old_bell_tower_locked"]
        },
        {
          "id": "objective",
          "role": "quest_hint",
          "text_id": "ftue_scout_road"
        },
        {
          "id": "reward_feedback",
          "role": "reward_chip",
          "initial_state": "hidden_until_first_reward"
        },
        {
          "id": "primary_action",
          "role": "button",
          "action": "road_scout_or_route_advance",
          "label_id": "scout_road_then_route_advance"
        },
        {
          "id": "upgrade_panel",
          "role": "panel",
          "initial_state": "hidden_until_first_reward"
        }
      ]
    },
    "encounter": {
      "trigger": "road_scout_starts_mire_wisp",
      "regions": [
        {
          "id": "enemy_panel",
          "role": "combatant",
          "contents": ["enemy_name", "enemy_hp", "enemy_intent"]
        },
        {
          "id": "combat_actions",
          "role": "button_row",
          "actions": ["strike", "spark", "guard", "retreat"]
        },
        {
          "id": "combat_log",
          "role": "feedback",
          "max_lines": 2
        }
      ]
    },
    "upgrade": {
      "trigger": "first_reward_claimed",
      "regions": [
        {
          "id": "spark_ward_1",
          "role": "upgrade_button",
          "cost": {
            "silver": 12,
            "rune_sparks": 1
          },
          "blocked_text_id": "needs_silver_and_spark"
        }
      ]
    }
  },
  "ftue_steps": [
    {
      "id": "see_goal",
      "screen": "main",
      "required_visible_action": "road_scout"
    },
    {
      "id": "first_scout",
      "action": "road_scout",
      "expected_feedback": "encounter_opens"
    },
    {
      "id": "first_spell",
      "action": "spark",
      "expected_feedback": "enemy_hp_decreases"
    },
    {
      "id": "first_reward",
      "action": "win_encounter",
      "expected_feedback": "silver_xp_spark_increase_and_reward_chip"
    },
    {
      "id": "first_upgrade",
      "action": "buy_spark_ward_1",
      "expected_feedback": "old_bell_tower_unlocked"
    }
  ],
  "devapi_nodes": [
    "root",
    "status.hp",
    "status.mana",
    "status.silver",
    "reward.last",
    "map.miregate",
    "map.wispfen_road",
    "map.old_bell_tower",
    "map.briar_gate",
    "map.moonwell",
    "map.ashen_cairn",
    "map.starfall_grotto",
    "action.scout_road",
    "action.choose_briar_gate",
    "action.choose_moonwell",
    "action.scout_briar_gate",
    "action.scout_moonwell",
    "action.discover_ashen_cairn",
    "action.discover_starfall_grotto",
    "combat.strike",
    "combat.spark",
    "upgrade.spark_ward_1",
    "upgrade.spark_ward_2"
  ]
}
