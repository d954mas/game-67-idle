{
  "schema": "game.live_state_acceptance_matrix",
  "project": "dragon-grove",
  "required_states": [
    "first_screen",
    "hud_visible",
    "primary_action_ready",
    "primary_action_feedback",
    "locked_or_disabled_state"
  ],
  "states": {
    "first_screen": {
      "required": true,
      "player_read_question": "Where am I, and what is the board?",
      "proof_prompt": "Native first-screen screenshot."
    },
    "hud_visible": {
      "required": true,
      "player_read_question": "What is the goal and current progress?",
      "proof_prompt": "HUD screenshot or zoom."
    },
    "primary_action_ready": {
      "required": true,
      "player_read_question": "Which three objects can merge now?",
      "proof_prompt": "Highlighted merge-ready objects."
    },
    "primary_action_feedback": {
      "required": true,
      "player_read_question": "What changed after the action?",
      "proof_prompt": "Post-merge screenshot/log."
    },
    "locked_or_disabled_state": {
      "required": true,
      "player_read_question": "Why is progress blocked, and what is needed?",
      "proof_prompt": "No-merge/blocked message."
    }
  }
}
